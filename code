function MarginPanel({pEu, pAp, ttfUsd, jkm, params}){
  const routes=[
    {id:"EU",label:"EU / TTF",  p:pEu, mkt:ttfUsd, color:T.cyan,  dest:"Rotterdam", alertThr:params.alertThresholdEU},
    {id:"AP",label:"AP / JKM",  p:pAp, mkt:jkm,    color:T.amber, dest:"Tokyo",      alertThr:params.alertThresholdAP},
  ];

  // BUG FIX v6.0: Use hhInput stored in profit result, not derived from acqPerMmbtu
  const hhDisplay = pEu.hhInput ?? 0;

  return(
    <Card accent={T.green}>
      <SH label="Margin over Break-even" right="$/MMBtu · Trader Primary KPI" accent={T.green}/>

      {/* SPA acquisition cost breakdown */}
      <div style={{background:T.bg2,border:`1px solid ${T.line}`,
        borderLeft:`2px solid ${T.amber}`,padding:"6px 9px",borderRadius:2,marginBottom:7}}>
        <div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.amber,
          letterSpacing:"0.14em",marginBottom:4}}>SPA ACQUISITION COST</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:5}}>
          {[
            // BUG FIX: use hhInput directly instead of acqPerMmbtu/spaSlope
            {l:"HH Spot",    v:`$${f3(hhDisplay)}`,             c:T.cyan},
            {l:"×Slope",     v:`×${params.spaSlope.toFixed(3)}`,c:T.textMid},
            {l:"+Tolling",   v:`+$${params.sTolling.toFixed(2)}`,c:T.amber},
            {l:"ACQ COST",   v:`$${pEu.acqPerMmbtu.toFixed(3)}/M`,c:T.red},
          ].map((s,i)=>(
            <div key={i}>
              <div style={{fontFamily:FC,fontSize:8,color:T.textDim}}>{s.l}</div>
              <div style={{fontFamily:FM,fontSize:11,fontWeight:700,color:s.c}}>{s.v}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Per-route margin analysis */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5}}>
        {routes.map(r=>{
          const inMoney   = r.p.marginPerMmbtu > 0;
          const belowAlert = r.p.marginPerMmbtu < r.alertThr && r.p.marginPerMmbtu >= 0;
          const marginPct = r.p.breakEvenDest > 0
            ? ((r.mkt - r.p.breakEvenDest) / r.p.breakEvenDest * 100) : 0;
          const borderColor = belowAlert ? T.amber : inMoney ? r.color : T.red;
          return(
            <div key={r.id} style={{background:T.bg2,padding:"7px 9px",borderRadius:2,
              border:`1px solid ${borderColor}`,
              borderLeft:`3px solid ${borderColor}`,
              // v6.0: amber pulse for low-but-positive margin (alert threshold)
              boxShadow: belowAlert ? `0 0 8px ${T.amber}44` : "none",
            }}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5}}>
                <div style={{fontFamily:FC,fontSize:10,fontWeight:700,
                  color:r.color,letterSpacing:"0.12em"}}>
                  {r.label} · {r.dest}
                  {r.p.blLocked && <span style={{fontFamily:FM,fontSize:7,
                    color:T.purple,marginLeft:6}}>🔒 B/L</span>}
                </div>
                {belowAlert && (
                  <span style={{fontFamily:FM,fontSize:7,color:T.amber,
                    background:`${T.amber}20`,border:`1px solid ${T.amber}66`,
                    padding:"1px 5px",borderRadius:2}}>
                    ⚠ LOW
                  </span>
                )}
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:4}}>
                {[
                  {l:"Market",       v:`$${f3(r.mkt)}`,                                c:r.color},
                  {l:"Break-even",   v:`$${f3(r.p.breakEvenDest)}`,                    c:T.textMid},
                  {l:"Margin/MMBtu", v:`${r.p.marginPerMmbtu>=0?"+":" "}$${f2(r.p.marginPerMmbtu)}`, c:inMoney?T.green:T.red},
                  {l:"Total Margin", v:fM(r.p.marginTotal),                             c:inMoney?T.green:T.red},
                  {l:"Margin %",     v:`${marginPct>=0?"+":""}${marginPct.toFixed(1)}%`, c:inMoney?T.green:T.red},
                  {l:"Deliver",      v:`${(r.p.deliv/1e6).toFixed(1)}M MMBtu`,          c:T.textMid},
                ].map((s,i)=>(
                  <div key={i}>
                    <div style={{fontFamily:FC,fontSize:8,color:T.textDim}}>{s.l}</div>
                    <div style={{fontFamily:FM,fontSize:10,fontWeight:700,color:s.c}}>{s.v}</div>
                  </div>
                ))}
              </div>
              <div style={{marginTop:5,background:T.bg0,borderRadius:2,height:6,overflow:"hidden"}}>
                <div style={{
                  height:"100%",borderRadius:2,transition:"width 0.4s",
                  background:inMoney?r.color:T.red,
                  width:`${Math.min(100,Math.max(0,(r.mkt/Math.max(r.p.breakEvenDest,0.1))*60))}%`,
                }}/>
              </div>
              <div style={{display:"flex",justifyContent:"space-between",
                fontFamily:FM,fontSize:7,color:T.textDim,marginTop:2}}>
                <span>$0</span>
                <span>BEP ${f3(r.p.breakEvenDest)}</span>
                <span>MKT ${f3(r.mkt)}</span>
              </div>
            </div>
          );
        })}
      </div>

      <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim,marginTop:6,
        paddingTop:4,borderTop:`1px solid ${T.line}`,
        display:"flex",gap:12,flexWrap:"wrap"}}>
        <span>Laden EU: {pEu.td.toFixed(1)}d</span>
        <span>+ Ballast: {pEu.ballastDays.toFixed(1)}d</span>
        <span style={{color:T.amber}}>Total charter: {fDol(pEu.charter)}</span>
        <span>Heel: {(pEu.heelMmbtu/1e3).toFixed(0)}k MMBtu locked</span>
        <span>Sea state: ×{SEA_STATE[params.seaState]?.mult.toFixed(2)}</span>
      </div>
    </Card>
  );
}

