          <Param label="JUMP SIZE σ_J" value={params.sigmaJump} min={0.05} max={1.0} step={0.05}
            onChange={v=>onUpdate("sigmaJump",v)} unit="(σ t-dist)" prec={2} color={T.redDim}
            note="0.30=moderate · 0.60=severe"/>
        </Sec>

        {/* v6.1: SOFR capital cost */}
        <Sec title="Capital Cost (SOFR)" accent={T.teal}
          sub={`Cost of capital tied up during voyage.\nAt ${params.sofr.toFixed(2)}%: EU voyage ~${fDol(
            (params.capacityM3*LNG_DENSITY*LNG_MMBTU_TON*(params.spaSlope*(hhLive)+params.sTolling+params.sLiquefaction))
            * (params.sofr/100) * (travelDays(NM.EU,params.speedKnots)/365)
          )} per cargo`}>
          <Param label="SOFR RATE" value={params.sofr} min={0.0} max={12.0} step={0.10}
            onChange={v=>onUpdate("sofr",v)} unit="%" prec={2} color={T.teal}
            note="Update to current SOFR. US fed funds rate proxy."/>
        </Sec>

        {/* v6.1: configurable JKM long-run mean */}
        <Sec title="OU Mean-Reversion Parameters" accent={T.purple}
          sub={`JKM long-run mean was hardcoded at $${(MU_HH*3.8+1.5).toFixed(1)}/M.\n2024-25 compressed to ~$12-14 on oversupply.\nCalibrate to current forward strip.`}>
          <Param label="μ JKM (long-run)" value={params.muJkm} min={6.0} max={30.0} step={0.25}
            onChange={v=>onUpdate("muJkm",v)} unit="$/MMBtu" prec={2} color={T.purple}
            note={`Currently: $${params.muJkm.toFixed(2)} · Legacy hardcoded: $${(MU_HH*3.8+1.5).toFixed(2)}`}/>
          <div style={{fontFamily:FM,fontSize:7,color:T.textDim,
            background:T.bg2,padding:"5px 7px",borderRadius:2,
            borderLeft:`2px solid ${T.purple}`,lineHeight:1.6}}>
            HH μ: $3.52 (EIA 24-25 avg) · TTF μ: €29.50<br/>
            These are fixed. Only JKM is user-configurable here<br/>
            as it has shifted most from historical calibration.
          </div>
        </Sec>

        <button onClick={()=>onUpdate("__RESET__",null)} style={{
          width:"100%",fontFamily:FC,fontSize:10,fontWeight:700,
          letterSpacing:"0.14em",color:T.textMid,background:"transparent",
          border:`1px solid ${T.line2}`,borderRadius:2,padding:"7px",
          cursor:"pointer",textTransform:"uppercase",
        }}>↺ RESET ALL DEFAULTS</button>
      </div>
    </>
  );
}

/* ════════════════════════════════════════════════════════════════════════
   TORNADO CHART — Sensitivity ±1%
════════════════════════════════════════════════════════════════════════ */
function TornadoChart({data}){
  if(!data?.length)return null;
  return(
    <ResponsiveContainer width="100%" height={158}>
      <BarChart data={data} layout="vertical"
        margin={{top:2,right:28,bottom:0,left:90}}>
        <CartesianGrid stroke={T.line} strokeDasharray="2 4" horizontal={false}/>
        <XAxis type="number"
          tick={{fill:T.textDim,fontSize:7,fontFamily:FM}}
          tickFormatter={v=>`${v>0?"+":""}${v.toFixed(1)}%`}
          domain={["dataMin - 0.5","dataMax + 0.5"]}/>
        <YAxis type="category" dataKey="subject" width={88}
          tick={{fill:T.textMid,fontSize:8,fontFamily:FC,fontWeight:700}}/>
        <ReferenceLine x={0} stroke="rgba(255,255,255,0.2)" strokeDasharray="3 2"/>
        <Tooltip content={<Tip pre="" dec={2}/>}/>
        <Bar dataKey="upside"   name="+1% Δ%" fill={`${T.green}BB`} isAnimationActive={false} radius={[0,2,2,0]}/>
        <Bar dataKey="downside" name="-1% Δ%" fill={`${T.red}BB`}   isAnimationActive={false} radius={[0,2,2,0]}/>
      </BarChart>
    </ResponsiveContainer>
  );
}

/* ════════════════════════════════════════════════════════════════════════
   MAIN DASHBOARD — LNG FRONTIER OPTIMIZER v6.0
════════════════════════════════════════════════════════════════════════ */
export default function LNGDashboard(){
  const [params,      setParams]      = useState(DP);
  const [px,          setPx]          = useState({hh:3.52,ttf:29.50,jkm:14.98,eurUsd:1.085,usdJpy:149.5});
  const [prevPx,      setPrevPx]      = useState(null);
  const [history,     setHistory]     = useState([]);
  const [marginH,     setMarginH]     = useState([]);
  const [spreadH,     setSpreadH]     = useState([]);
  const [mc,          setMc]          = useState(null);
  const [volMode,     setVolMode]     = useState("normal");
  const [isLive,      setIsLive]      = useState(true);
  const [tick,        setTick]        = useState(0);
  const [fxOk,        setFxOk]        = useState(false);
  const [fxAge,       setFxAge]       = useState(0);
  const [stressMode,  setStressMode]  = useState(null);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  // v6.0: Regime state — 2-state Markov (normal / crisis)
  const [regime,      setRegime]      = useState("normal");
  // v6.0: Stable forward curve seeds — regenerate only every 30 ticks
  const [fwdSeeds,    setFwdSeeds]    = useState(()=>
    Array.from({length:12},()=>[randn(),randn(),randn()])
  );
  const tickRef=useRef(0), intRef=useRef(null);

  const updateParam=useCallback((key,val)=>{
    if(key==="__RESET__"){setParams(DP);return;}
    setParams(p=>({...p,[key]:val}));
  },[]);

  // Apply stress multipliers non-destructively
  const spx=useMemo(()=>{
    if(!stressMode)return px;
    const s=SS[stressMode];
    return{...px,hh:px.hh*s.mHH,ttf:px.ttf*s.mTTF,jkm:px.jkm*s.mJKM};
  },[px,stressMode]);

  /* ── BCE FX every 60s ─────────────────────────────────────────── */
  useEffect(()=>{
    let ageT;
    async function doFX(){
      const r=await fetchFX();
      if(r){
        setPx(p=>({...p,eurUsd:r.eurUsd,usdJpy:r.usdJpy}));
        setFxOk(true);setFxAge(0);
        clearInterval(ageT);
        ageT=setInterval(()=>setFxAge(a=>a+1),1000);
      }
    }
    doFX();
    const fxId=setInterval(doFX,60_000);
    ageT=setInterval(()=>setFxAge(a=>a+1),1000);
    return()=>{clearInterval(fxId);clearInterval(ageT);};
  },[]);

  /* ── Seed historical data ─────────────────────────────────────── */
  useEffect(()=>{
    const vols=VOL_PRESETS.normal;
    let s={hh:3.52,ttf:29.50,jkm:14.98,eurUsd:1.085,usdJpy:149.5};
    const h=[],mh=[],sh=[];
    for(let i=85;i>=0;i--){
      const ns=ouStep(s,vols,1/365/24,"normal",DP.muJkm);
      s={...ns,eurUsd:s.eurUsd,usdJpy:s.usdJpy};
      const ttfU=ttfToUsd(s.ttf,s.eurUsd);
      const t=new Date(Date.now()-i*2000)
        .toLocaleTimeString("it-IT",{hour:"2-digit",minute:"2-digit",second:"2-digit"});
      h.push({t,hh:s.hh,ttf:ttfU,jkm:s.jkm});
      sh.push({t,eu:ttfU-s.hh,ap:s.jkm-s.hh});
      const pE=calcProfit(s.hh,ttfU, DP,"EU");
      const pA=calcProfit(s.hh,s.jkm,DP,"AP");
      mh.push({t,eu:pE.marginPerMmbtu,ap:pA.marginPerMmbtu});
    }
    setHistory(h);setSpreadH(sh);setMarginH(mh);
    setPx(p=>({...p,hh:s.hh,ttf:s.ttf,jkm:s.jkm}));
    setMc(runMCAdvanced(s.hh,ttfToUsd(s.ttf,1.085),s.jkm,DP,vols,null,"normal"));
  },[]);

  /* ── Tick Engine with Regime Markov transitions ───────────────── */
  const doTick=useCallback(()=>{
    const vols=VOL_PRESETS[volMode];
    setPx(prev=>{
      setPrevPx({...prev});

      // v6.0: Markov regime transition
      setRegime(curRegime=>{
        const reg = REGIME[curRegime];
        const nextRegime = Math.random() < reg.pTransition
          ? (curRegime === "normal" ? "crisis" : "normal")
          : curRegime;
        return nextRegime;
      });

      const ns=ouStep(prev,vols,1/365/24,regime,params.muJkm);
      ns.eurUsd=prev.eurUsd;ns.usdJpy=prev.usdJpy;
      const ttfU=ttfToUsd(ns.ttf,ns.eurUsd);
      const now=ts();
      setHistory(h=>[...h.slice(-89),{t:now,hh:ns.hh,ttf:ttfU,jkm:ns.jkm}]);
      setSpreadH(h=>[...h.slice(-89),{t:now,eu:ttfU-ns.hh,ap:ns.jkm-ns.hh}]);
      const pE=calcProfit(ns.hh,ttfU, params,"EU");
      const pA=calcProfit(ns.hh,ns.jkm,params,"AP");
      setMarginH(h=>[...h.slice(-89),{t:now,eu:pE.marginPerMmbtu,ap:pA.marginPerMmbtu}]);

      tickRef.current++;

      // Regenerate forward curve seeds every 30 ticks (stable for ~60s)
      if(tickRef.current%30===0)
        setFwdSeeds(Array.from({length:12},()=>[randn(),randn(),randn()]));

      if(tickRef.current%8===0)
        setMc(runMCAdvanced(ns.hh,ttfU,ns.jkm,params,vols,stressMode,regime));

      setTick(tickRef.current);
      return ns;
    });
  },[volMode,params,stressMode,regime]);

  useEffect(()=>{
    if(isLive){intRef.current=setInterval(doTick,2000);}
    else clearInterval(intRef.current);
    return()=>clearInterval(intRef.current);
  },[isLive,doTick]);

  /* ── Derived values ───────────────────────────────────────────── */
  const ttfUsd    = ttfToUsd(spx.ttf,spx.eurUsd);
  const pEu       = calcProfit(spx.hh,ttfUsd,  params,"EU");
  const pAp       = calcProfit(spx.hh,spx.jkm, params,"AP");
  const prevTtfUsd= prevPx?ttfToUsd(prevPx.ttf,prevPx.eurUsd):ttfUsd;

  const rawOptId  = pEu.marginTotal>=pAp.marginTotal?"EU":"AP";
  const riskOptId = (mc?.eu?.sharpe??0)>=(mc?.ap?.sharpe??0)?"EU":"AP";
  const conflict  = rawOptId!==riskOptId;
  const optimal   = rawOptId==="EU"
    ?{id:"EU",label:"Europa",  dest:"TTF",p:pEu}
    :{id:"AP",label:"Asia-Pac",dest:"JKM",p:pAp};

  const rte=useMemo(()=>calcRouteBreakeven(spx.hh,spx.jkm,params),[spx.hh,spx.jkm,params]);
  const div=useMemo(()=>calcCargoDiversion(spx.hh,ttfUsd,spx.jkm,params,0.5),[spx.hh,ttfUsd,spx.jkm,params]);

  const sensi=useMemo(()=>
    Array.from({length:22},(_,i)=>{
      const cr=40_000+i*5_000;
      const res=calcProfit(spx.hh,ttfUsd,{...params,charterRate:cr},"EU");
      return{cr:cr/1000,margin:res.marginPerMmbtu,profit:res.profit/1e6};
    }),[spx.hh,ttfUsd,params]);

  const spider=useMemo(()=>calcSpider(params,spx.hh,ttfUsd,spx.jkm),[params,spx.hh,spx.jkm,ttfUsd]);

  // BUG FIX v6.0: Use actual params.borRate and seaState in boiloff chart
  // Previously hardcoded 0.001/0.0015/0.002 — chart never updated with params
  const boiloff=useMemo(()=>{
    const seaMult = SEA_STATE[params.seaState]?.mult ?? 1.0;
    const borNom  = params.borRate / 100;
    // Show three scenarios: calm baseline, current sea state, storm
    const borLo   = borNom * SEA_STATE.calm.mult;   // best case
    const borNm   = borNom * seaMult;                // current params
    const borHi   = borNom * SEA_STATE.storm.mult;  // worst case
    return Array.from({length:30},(_,i)=>({
      d:i+1,
      lo:Math.pow(1-borLo/100, i+1)*100,    // Note: borNom already /100 above
      nm:Math.pow(1-borNm, i+1)*100,
      hi:Math.pow(1-borHi, i+1)*100,
    }));
  // eslint-disable-next-line react-hooks/exhaustive-deps
  },[params.borRate, params.seaState]);

  // BUG FIX v6.0: Forward curve uses stable fwdSeeds (no random on every render)
  const fwd=useMemo(()=>fwdSeeds.map((z,i)=>{
    const t=(i+1)/12;
    return{
      m:`M${i+1}`,
      hh:  Math.max(0.30, spx.hh  +(MU.hh  -spx.hh )*OU_KAPPA*t + z[0]*0.02),
      ttf: Math.max(3.00, ttfUsd  +(MU.ttf/3.41214-ttfUsd)*(OU_KAPPA*t*0.4) + z[1]*0.12),
      jkm: Math.max(6.00, spx.jkm +(params.muJkm -spx.jkm)*OU_KAPPA*t + z[2]*0.08),
    };
  }),[fwdSeeds, spx.hh, spx.jkm, ttfUsd, params.muJkm]);

  const fwdSlope=fwd.length>1?fwd[11].ttf-fwd[0].ttf:0;
  const curveLbl=fwdSlope>0.5?"CONTANGO":fwdSlope<-0.5?"BACKWARDATION":"FLAT";
  const curveCol=curveLbl==="CONTANGO"?T.amber:curveLbl==="BACKWARDATION"?T.green:T.textMid;

  const wf=[
    {n:"Acq.(SPA)",v:-(pEu.supply/1e6),       fill:T.redDim},
    {n:"Charter",  v:-(pEu.charter/1e6),       fill:T.amber},
    {n:"Fuel",     v:-(pEu.fuel/1e6),          fill:T.amberDim},
    {n:"Capital",  v:-(pEu.capitalCost/1e6),   fill:T.purple},
    {n:"Regas",    v:-(pEu.regas/1e6),         fill:"#9B6020"},
    {n:"Ports",    v:-(pEu.ports/1e6),         fill:T.textDim},
    {n:"Revenue",  v: pEu.revenue/1e6,         fill:T.cyan},
    {n:"MARGIN",   v: pEu.profit/1e6,          fill:pEu.profit>0?T.green:T.red},
  ];

  const stressActive=stressMode&&SS[stressMode];
  const regimeInfo = REGIME[regime];

  // v6.0: Kelly fraction hint (simplified)  E[r] / σ² for position sizing guidance
  const kellyEU  = mc ? (mc.eu.mean / Math.max(mc.eu.std**2, 1)) * 1e6 : null; // normalize
  const kellySuggestion = kellyEU !== null
    ? Math.max(0, Math.min(100, Math.round(kellyEU * 0.5)))  // half-Kelly, cap 100%
    : null;

  /* ═══ RENDER ══════════════════════════════════════════════════════ */
  return(
    <div style={{width:"100%",minHeight:"100vh",background:T.bg0,color:T.text,
      fontFamily:FM,overflowX:"hidden"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Barlow+Condensed:wght@400;600;700;800&display=swap');
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        html,body,#root{width:100%;overflow-x:hidden}
        ::-webkit-scrollbar{width:4px;height:4px}
        ::-webkit-scrollbar-track{background:${T.bg0}}
        ::-webkit-scrollbar-thumb{background:${T.line2};border-radius:2px}
        .ctrl{cursor:pointer;border:1px solid ${T.line2};border-radius:2px;padding:4px 10px;
          font-family:${FC};font-size:11px;font-weight:700;letter-spacing:0.1em;
          background:transparent;transition:all .12s;text-transform:uppercase;color:${T.textMid}}
        .ctrl:hover{background:${T.bg3};border-color:${T.cyan};color:${T.cyan}}
        .ctrl.active{background:${T.bg2};border-color:${T.cyan};color:${T.cyan}}
        .ldot{animation:lp 1.6s ease-in-out infinite}
        @keyframes lp{0%,100%{opacity:1;box-shadow:0 0 6px ${T.green}}50%{opacity:.2;box-shadow:none}}
        .crs-pulse{animation:crp 0.8s ease-in-out infinite}
        @keyframes crp{0%,100%{opacity:1;box-shadow:0 0 8px ${T.red}}50%{opacity:0.5;box-shadow:none}}
        input[type=range]{-webkit-appearance:none;height:3px;border-radius:2px;
          background:${T.line2};outline:none;cursor:pointer;width:100%}
        input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:11px;height:11px;
          border-radius:50%;background:${T.cyan};cursor:pointer;border:2px solid ${T.bg0}}
      `}</style>

      <Sidebar params={params} onUpdate={updateParam} isOpen={sidebarOpen}
        onToggle={()=>setSidebarOpen(o=>!o)} px={px}/>

      <div style={{width:"100%",padding:"10px 13px"}}>

        {/* ── TOP BAR ───────────────────────────────────────────── */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",
          marginBottom:8,paddingBottom:8,borderBottom:`1px solid ${T.line2}`,flexWrap:"wrap",gap:5}}>
          <div>
            <div style={{fontFamily:FC,fontWeight:800,fontSize:20,color:T.cyan,
              letterSpacing:"0.03em",lineHeight:1,display:"flex",alignItems:"baseline",gap:9,flexWrap:"wrap"}}>
              LNG FRONTIER OPTIMIZER
              <span style={{fontFamily:FM,fontSize:8,color:T.red,
                background:`${T.red}18`,border:`1px solid ${T.red}44`,
                padding:"2px 7px",borderRadius:2,letterSpacing:"0.12em"}}>
                TRADER EDITION v6.1
              </span>
              {/* v6.0: Regime indicator */}
              <span className={regime==="crisis"?"crs-pulse":""} style={{
                fontFamily:FM,fontSize:8,color:regimeInfo.color,
                background:`${regimeInfo.color}18`,border:`1px solid ${regimeInfo.color}`,
                padding:"2px 7px",borderRadius:2,letterSpacing:"0.1em",
              }}>
                {regime==="crisis"?"⚡":"●"} {regimeInfo.shortLabel}
              </span>
              {stressActive&&(
                <span style={{fontFamily:FM,fontSize:8,color:stressActive.color,
                  background:`${stressActive.color}20`,border:`1px solid ${stressActive.color}`,
                  padding:"2px 8px",borderRadius:2,animation:"lp 1.2s infinite"}}>
                  {stressActive.icon} {stressActive.label}
                </span>
              )}
              {params.blPriceLocked&&(
                <span style={{fontFamily:FM,fontSize:8,color:T.purple,
                  background:`${T.purple}20`,border:`1px solid ${T.purple}`,
                  padding:"2px 8px",borderRadius:2}}>
                  🔒 B/L LOCKED
                </span>
              )}
            </div>
            <div style={{fontFamily:FC,fontSize:10,color:T.textMid,letterSpacing:"0.1em",marginTop:2}}>
              Henry Hub (USA) ↔ TTF (Europa) ↔ JKM (Asia-Pacific)
              <span style={{marginLeft:10,color:T.textDim}}>
                SPA acq: ${pEu.acqPerMmbtu.toFixed(2)}/M · BEP EU: ${pEu.breakEvenDest.toFixed(2)} · BEP AP: ${pAp.breakEvenDest.toFixed(2)}
                <span style={{marginLeft:6,color:T.teal}}>· v6.0: Student-t jumps + CVaR + charter corr.</span>
              </span>
            </div>
          </div>
          <div style={{display:"flex",gap:5,alignItems:"center",flexWrap:"wrap"}}>
            <div style={{fontFamily:FM,fontSize:9,color:T.textMid,background:T.bg2,
              border:`1px solid ${T.line}`,padding:"3px 8px",borderRadius:2,
              display:"flex",alignItems:"center",gap:4}}>
              <span style={{color:fxOk&&fxAge<90?T.green:T.amber,fontSize:10}}>●</span>
              FX BCE {fxOk?`${fxAge}s`:"fallback"}
            </div>
            {["low","normal","high"].map(v=>(
              <button key={v} className={`ctrl ${volMode===v?"active":""}`}
                onClick={()=>setVolMode(v)}>σ {v}</button>
            ))}
            <button className="ctrl" onClick={()=>setSidebarOpen(o=>!o)}
              style={{color:T.purple,borderColor:T.purple,background:`${T.purple}10`}}>
              ⚙ PARAMS
            </button>
            <button className="ctrl" onClick={()=>setIsLive(l=>!l)}
              style={{color:isLive?T.red:T.green,borderColor:isLive?T.red:T.green,
                background:isLive?`${T.red}10`:`${T.green}10`}}>
              {isLive?"⏸ STOP":"▶ LIVE"}
            </button>
            <div style={{display:"flex",alignItems:"center",gap:4,
              fontFamily:FM,fontSize:10,color:T.textMid}}>
              <div className={isLive?"ldot":""} style={{width:6,height:6,borderRadius:"50%",
                background:isLive?T.green:T.textDim}}/>
              {isLive?"LIVE":"PAUSED"} · #{tick}
            </div>
          </div>
        </div>

        {/* ── STRESS PANEL ──────────────────────────────────────── */}
        <StressPanel stressMode={stressMode} setStressMode={setStressMode}/>

        {/* ── TICKER STRIP ──────────────────────────────────────── */}
        <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:5,marginBottom:6}}>
          <Ticker label="HENRY HUB"    value={f3(spx.hh)}     delta={spx.hh   -(prevPx?.hh   ??spx.hh)}    unit="$/MMBtu" color={T.green}/>
          <Ticker label="TTF"          value={f3(spx.ttf)}    delta={spx.ttf  -(prevPx?.ttf  ??spx.ttf)}   unit="€/MWh"   color={T.cyan}/>
          <Ticker label="TTF (USD)"    value={f3(ttfUsd)}     delta={ttfUsd   -prevTtfUsd}                  unit="$/MMBtu" color={T.cyan}/>
          <Ticker label="JKM"          value={f3(spx.jkm)}    delta={spx.jkm  -(prevPx?.jkm  ??spx.jkm)}   unit="$/MMBtu" color={T.amber}/>
          <Ticker label="EUR/USD"      value={f3(spx.eurUsd)} delta={spx.eurUsd-(prevPx?.eurUsd??spx.eurUsd)} unit=""      color={T.purple}/>
          <Ticker label="MARGIN EU"    value={f2(pEu.marginPerMmbtu)} delta={pEu.marginPerMmbtu-(calcProfit(prevPx?.hh??spx.hh,prevTtfUsd,params,"EU").marginPerMmbtu)} unit="$/MMBtu" color={pEu.marginPerMmbtu>0?T.green:T.red}/>
          <Ticker label="MARGIN AP"    value={f2(pAp.marginPerMmbtu)} delta={pAp.marginPerMmbtu-(calcProfit(prevPx?.hh??spx.hh,prevPx?.jkm??spx.jkm,params,"AP").marginPerMmbtu)} unit="$/MMBtu" color={pAp.marginPerMmbtu>0?T.green:T.red}/>
        </div>

        {/* ── ROW A: Spot Prices | Spread | Margin Analysis ─────── */}
        <div style={{display:"grid",gridTemplateColumns:"1.6fr 1fr 1.5fr",gap:5,marginBottom:5}}>
          <Card accent={T.cyan}>
            <SH label="Prezzi Spot — OU Mean-Reversion" right={`σ=${volMode} · ${regimeInfo.shortLabel} · ${ts()}`}/>
            <ResponsiveContainer width="100%" height={158}>
              <LineChart data={history} margin={{top:2,right:4,bottom:0,left:-20}}>
                <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
                <XAxis dataKey="t" tick={{fill:T.textDim,fontSize:8,fontFamily:FM}}
                  interval={Math.floor(history.length/5)}/>
                <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FM}}/>
                <Tooltip content={<Tip dec={3}/>}/>
                <Line dataKey="hh"  name="HH"    stroke={T.green} dot={false} strokeWidth={1.6} isAnimationActive={false}/>
                <Line dataKey="ttf" name="TTF$"  stroke={T.cyan}  dot={false} strokeWidth={1.6} isAnimationActive={false}/>
                <Line dataKey="jkm" name="JKM"   stroke={T.amber} dot={false} strokeWidth={1.6} isAnimationActive={false}/>
              </LineChart>
            </ResponsiveContainer>
          </Card>

