                onChange={v=>onUpdate("blPriceEU",v)} unit="$/MMBtu" prec={2} color={T.purple}
                note="Fixed EU sell price at B/L"/>
              <Param label="B/L PRICE AP" value={params.blPriceAP||12} min={3} max={50} step={0.10}
                onChange={v=>onUpdate("blPriceAP",v)} unit="$/MMBtu" prec={2} color={T.purple}
                note="Fixed AP sell price at B/L"/>
            </>
          )}
        </Sec>

        {/* Stochastic */}
        <Sec title="Jump Diffusion — Merton 1976" accent={T.red}>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim,marginBottom:8,
            background:T.bg2,padding:"6px 8px",borderRadius:2,
            borderLeft:`2px solid ${T.red}`,lineHeight:1.7}}>
            dS = OU(κ,μ,σ)·dt + J·dN(λ)<br/>
            Hawkes: P(J_JKM|J_TTF) += 60%<br/>
            Suez: stochastic delay LogNormal(0,0.8)
          </div>
          <Param label="JUMP INTENSITY λ" value={params.lambdaJump} min={0} max={4} step={0.1}
            onChange={v=>onUpdate("lambdaJump",v)} unit="/yr" prec={1} color={T.red}/>
          <Param label="JUMP SIZE σ_J" value={params.sigmaJump} min={0.05} max={1.0} step={0.05}
            onChange={v=>onUpdate("sigmaJump",v)} unit="(σ log)" prec={2} color={T.redDim}
            note="0.30=moderate · 0.60=severe"/>
        </Sec>

        <button onClick={()=>onUpdate("__RESET__",null)} style={{
          width:"100%",fontFamily:FC,fontSize:10,fontWeight:700,
          letterSpacing:"0.14em",color:T.textMid,background:"transparent",
          border:`1px solid ${T.line2}`,borderRadius:2,padding:"7px",
          cursor:"pointer",textTransform:"uppercase",
        }}>↺ RESET ALL DEFAULTS</button>
      </div>
    </>
  );
}

