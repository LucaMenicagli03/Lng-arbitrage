        color:T.purple,cursor:"pointer",padding:"12px 5px",
        borderRadius:"0 4px 4px 0",fontFamily:FM,fontSize:12,
        transition:"left 0.26s cubic-bezier(.4,0,.2,1)",lineHeight:1,
        boxShadow:"4px 0 16px rgba(0,0,0,.6)",
      }}>{isOpen?"◀":"▶"}</button>

      <div style={{
        position:"fixed",left:0,top:0,bottom:0,width:284,
        background:T.bg0,borderRight:`1px solid ${T.line2}`,
