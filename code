/** GIE AGSI+ — EU aggregated gas storage fill level (% + TWh)
 *  NUOVO v7.1: il dato fondamentale più importante per il prezzo TTF
 *  Aggiornamento: ogni giorno alle 19:30 CET
 *  Auth: x-key header
 */
async function fetchAGSI() {
  try {
    // Endpoint aggregato EU — ultimi 5 giorni per calcolare trend
    const url = `https://agsi.gie.eu/api?country=EU&size=5`;
    const r = await fetch(url, {
      signal: AbortSignal.timeout(10000),
      headers: { "x-key": API.GIE, "Accept": "application/json" },
    });
    if(!r.ok) throw new Error(`AGSI ${r.status}`);
    const d = await r.json();
    const data = d?.data ?? d?.gasInStorage ?? d ?? [];
    const arr  = Array.isArray(data) ? data : [data];
    if(!arr.length) return null;
    const cur = arr[0];
    const prev= arr[1] ?? cur;
    // Normalizza campi — AGSI cambia i nomi dei campi tra versioni API
    const fill    = parseFloat(cur.full ?? cur.fill ?? cur.status ?? 0);
    const fillPrev= parseFloat(prev.full ?? prev.fill ?? prev.status ?? 0);
    const wgv     = parseFloat(cur.gasInStorage ?? cur.workingGasVolume ?? 0); // TWh
    const cap     = parseFloat(cur.capacity ?? cur.fullCapacity ?? 0);
    const inj     = parseFloat(cur.injection ?? 0);
    const wit     = parseFloat(cur.withdrawal ?? 0);
    const gasDt   = cur.gasDayStart ?? cur.date ?? "—";
    // Benchmark: fill% anno scorso e media 5 anni
    // (non disponibili direttamente, stimiamo da variazione storica)
    // Classificazione: < 30% critico, 30-50% basso, 50-70% normale, > 70% alto
    const fillClass = fill<30?"CRITICAL":fill<50?"LOW":fill<70?"NORMAL":"HIGH";
    const fillColor = fill<30?T.red:fill<50?T.amber:fill<70?T.cyan:T.green;
    // TTF signal: basso fill → bullish TTF (prezzi più alti)
    const ttfBullish = fill < 55;
    return {
      fill, fillPrev, fillDelta:fill-fillPrev,
      wgv, cap, inj, wit, gasDt,
      fillClass, fillColor, ttfBullish,
      dq:"LIVE", source:"GIE AGSI+",
    };
  } catch(e) {
    console.warn("AGSI+:",e.message);
    return null;
  }
}

/** GIE ALSI+ — EU LNG terminal inventory + sendout
 *  NUOVO v7.1: inventario terminali + sendout indica quanto LNG
 *  viene rigassificato in EU → bearish TTF se alto sendout
 */
async function fetchALSI() {
  try {
    const url = `https://alsi.gie.eu/api?country=EU&size=5`;
    const r = await fetch(url, {
      signal: AbortSignal.timeout(10000),
      headers: { "x-key": API.GIE, "Accept": "application/json" },
    });
    if(!r.ok) throw new Error(`ALSI ${r.status}`);
    const d = await r.json();
    const data = d?.data ?? d?.lngInventory ?? d ?? [];
    const arr  = Array.isArray(data) ? data : [data];
    if(!arr.length) return null;
    const cur = arr[0];
    const prev= arr[1] ?? cur;
    const inv     = parseFloat(cur.lngInventory ?? cur.inventory ?? cur.dtmi ?? 0);
    const invPrev = parseFloat(prev.lngInventory ?? prev.inventory ?? prev.dtmi ?? 0);
    const sendout = parseFloat(cur.sendOut ?? cur.lngSendOut ?? 0);  // GWh/d
    const cap     = parseFloat(cur.dtrs ?? cur.capacity ?? 0);
    const utilPct = cap>0 ? (sendout/cap*100) : 0;
    const gasDt   = cur.gasDayStart ?? cur.date ?? "—";
    // Alto sendout → più gas sul mercato → leggermente bearish TTF
    const ttfBearish = utilPct > 65;
    return {
      inv, invPrev, invDelta:inv-invPrev,
      sendout, cap, utilPct, gasDt,
      ttfBearish, dq:"LIVE", source:"GIE ALSI+",
    };
  } catch(e) {
    console.warn("ALSI+:",e.message);
    return null;
  }
}

