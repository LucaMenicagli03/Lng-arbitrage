function Ticker({label,value,delta,unit,color}){
  const ref=useRef();
  useEffect(()=>{
    if(!ref.current)return;
    ref.current.style.color=T.flash;
    const t=setTimeout(()=>{if(ref.current)ref.current.style.color=color;},120);
    return()=>clearTimeout(t);
  },[value]);
  return(
    <Card accent={color} style={{padding:"8px 10px"}}>
      <div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.textMid,
        letterSpacing:"0.14em",textTransform:"uppercase",marginBottom:3}}>{label}</div>
