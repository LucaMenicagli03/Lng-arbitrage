          sub="Warn when margin falls below threshold (amber ring)">
          <Param label="ALERT EU" value={params.alertThresholdEU} min={0} max={2.0} step={0.05}
            onChange={v=>onUpdate("alertThresholdEU",v)} unit="$/MMBtu" prec={2} color={T.teal}
            note="Margin alert floor for EU route"/>
          <Param label="ALERT AP" value={params.alertThresholdAP} min={0} max={2.0} step={0.05}
            onChange={v=>onUpdate("alertThresholdAP",v)} unit="$/MMBtu" prec={2} color={T.teal}
            note="Margin alert floor for AP route"/>
        </Sec>

        <Sec title="Cargo Position — B/L Price Lock" accent={T.purple}
          sub="Lock sell price at B/L date. Revenue fixed, not live.">
          <Toggle label="B/L PRICE LOCK" value={params.blPriceLocked}
            onChange={v=>onUpdate("blPriceLocked",v)} color={T.purple}/>
