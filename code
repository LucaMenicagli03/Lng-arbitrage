    <div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:accent,letterSpacing:"0.18em",textTransform:"uppercase",marginBottom:2,paddingBottom:4,borderBottom:`1px solid ${T.line2}`}}>{title}</div>
    {sub&&<div style={{fontFamily:FM,fontSize:7.5,color:T.textDim,marginBottom:6,lineHeight:1.5}}>{sub}</div>}
