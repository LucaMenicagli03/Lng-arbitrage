            onChange={v=>onUpdate("charterRate",v)} unit="$/day" prec={0} color={T.green}
            note="v6.0: MC models crisis-correlation spike with TTF jumps"/>
          <Param label="BALLAST FACTOR" value={params.ballastFactor} min={0.50} max={1.20} step={0.05}
            onChange={v=>onUpdate("ballastFactor",v)} unit="× laden" prec={2} color={T.amber}
            note={`Ballast EU: ${(travelDays(NM.EU,params.speedKnots)*params.ballastFactor).toFixed(1)}d`}/>
        </Sec>

        <Sec title="Routing — Suez vs Cape" accent={T.amberDim}>
          <Toggle label="USE CAPE OF GOOD HOPE" value={params.useCape}
            onChange={v=>onUpdate("useCape",v)}
            note={`+${(NM.AP_CAPE-NM.AP_SUEZ).toLocaleString()}nm · no canal fee`}/>
          <Toggle label="SUEZ WAR RISK ACTIVE" value={params.suezWarActive}
            onChange={v=>onUpdate("suezWarActive",v)} color={T.red}
            note={`+${fDol(params.warRiskSuez)} surcharge`}/>
          <Param label="SUEZ CANAL FEE" value={params.canalAP} min={0} max={1200000} step={10000}
            onChange={v=>onUpdate("canalAP",v)} unit="$" prec={0} color={T.amber}/>
          <Param label="WAR RISK $" value={params.warRiskSuez} min={0} max={1000000} step={25000}
            onChange={v=>onUpdate("warRiskSuez",v)} unit="$" prec={0} color={T.red}/>
          <Param label="DIVERSION PENALTY" value={params.diversionPenalty} min={0} max={3000000} step={50000}
            onChange={v=>onUpdate("diversionPenalty",v)} unit="$" prec={0} color={T.amber}/>
        </Sec>

        <Sec title="Terminal Fees" accent={T.amberDim}>
          <Param label="PORT ORIGIN" value={params.portOrigin} min={100000} max={600000} step={5000}
            onChange={v=>onUpdate("portOrigin",v)} unit="$" prec={0} color={T.textMid}/>
          <Param label="PORT DEST" value={params.portDest} min={100000} max={700000} step={5000}
            onChange={v=>onUpdate("portDest",v)} unit="$" prec={0} color={T.textMid}/>
          <Param label="REGAS FEE (EU)" value={params.regasFeeEU} min={0.10} max={0.80} step={0.01}
            onChange={v=>onUpdate("regasFeeEU",v)} unit="$/MMBtu" prec={2}/>
          <Param label="REGAS FEE (AP)" value={params.regasFeeAP} min={0.10} max={0.80} step={0.01}
            onChange={v=>onUpdate("regasFeeAP",v)} unit="$/MMBtu" prec={2} color={T.amber}/>
