            <SH label="Decision Engine" right={ts()}/>
            <div style={{display:"flex",flexDirection:"column",gap:5}}>
              {mc?.riskWarn&&<div style={{background:`${T.red}18`,border:`1px solid ${T.red}66`,borderLeft:`3px solid ${T.red}`,padding:"5px 9px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:10,fontWeight:700,color:T.red}}>⚠ RISK WARNING — AP</div><div style={{fontFamily:FM,fontSize:7.5,color:T.textMid}}>Vol {mc.volRatio.toFixed(2)}× EU · Sharpe AP {mc.ap.sharpe.toFixed(2)}</div></div>}
              {regime==="crisis"&&<div style={{background:`${T.red}14`,border:`1px solid ${T.red}55`,borderLeft:`2px solid ${T.red}`,padding:"4px 8px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.red}}>⚡ CRISIS REGIME</div></div>}
              {conflict&&<div style={{background:`${T.amber}12`,border:`1px solid ${T.amber}44`,borderLeft:`2px solid ${T.amber}`,padding:"4px 8px",borderRadius:2}}><div style={{fontFamily:FM,fontSize:8,color:T.amber}}>⚡ Raw: {rawOptId} ≠ Risk-adj: {riskOptId}</div></div>}
              {div.shouldDivert&&<div style={{background:`${T.amber}14`,border:`1px solid ${T.amber}55`,borderLeft:`3px solid ${T.amber}`,padding:"5px 9px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.amber}}>🔀 DIVERSION SIGNAL (50%)</div><div style={{fontFamily:FM,fontSize:7.5,color:T.textMid}}>ΔRev {fM(div.delta)} · JKM≥${div.jkmThreshold.toFixed(2)}</div></div>}
              {/* AGSI signal in decision engine */}
              {realPrices.agsi?.ttfBullish&&<div style={{background:`${T.green}0C`,border:`1px solid ${T.green}22`,borderLeft:`2px solid ${T.green}`,padding:"4px 8px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.green}}>📊 AGSI BULLISH TTF</div><div style={{fontFamily:FM,fontSize:7.5,color:T.textMid}}>EU fill {f1(realPrices.agsi.fill)}% — pressione rialzista TTF</div></div>}
              <div style={{background:`${T.green}0C`,border:`1px solid ${T.green}2A`,borderLeft:`3px solid ${T.green}`,padding:"7px 10px",borderRadius:2}}>
                <div style={{fontFamily:FC,fontSize:9,color:T.textMid,letterSpacing:"0.14em",marginBottom:2}}>DESTINAZIONE OTTIMALE</div>
                <div style={{fontFamily:FC,fontSize:17,fontWeight:800,color:T.green,lineHeight:1}}>{optimal.label}<span style={{fontSize:12,color:T.greenDim}}> ({optimal.dest})</span></div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:5,marginTop:6}}>
                  {[{l:"MARGIN/MMBtu",v:`${optimal.p.marginPerMmbtu>=0?"+":""}$${f2(optimal.p.marginPerMmbtu)}`,c:pColor(optimal.p.marginPerMmbtu)},{l:"TOTAL MARGIN",v:fM(optimal.p.marginTotal),c:pColor(optimal.p.marginTotal)},{l:"TOTAL DAYS",v:`${(optimal.p.td+optimal.p.ballastDays).toFixed(0)}d`,c:T.textMid}].map((s,i)=>(<div key={i}><div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>{s.l}</div><div style={{fontFamily:FM,fontSize:12,fontWeight:700,color:s.c}}>{s.v}</div></div>))}
                </div>
              </div>
              {[{id:"EU",label:"Europa",dest:"TTF",p:pEu,mcs:mc?.eu},{id:"AP",label:"Asia-Pac",dest:"JKM",p:pAp,mcs:mc?.ap}].map(item=>(<div key={item.id} style={{background:T.bg2,padding:"6px 9px",borderRadius:2,border:`1px solid ${item.id===rawOptId?T.green:T.line}`}}>
                <div style={{display:"grid",gridTemplateColumns:"0.7fr 0.9fr 0.8fr 1fr",gap:4,alignItems:"center"}}>
                  <div><div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>ROTTA</div><div style={{fontFamily:FC,fontSize:12,fontWeight:700,color:item.id===rawOptId?T.green:T.text}}>{item.dest}{item.id===rawOptId?" ★":""}</div></div>
                  <div><div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>MARGIN/M</div><div style={{fontFamily:FM,fontSize:11,fontWeight:700,color:pColor(item.p.marginPerMmbtu)}}>$${f2(item.p.marginPerMmbtu)}</div></div>
                  <div><div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>SHARPE</div><div style={{fontFamily:FM,fontSize:11,fontWeight:700,color:item.mcs?(item.mcs.sharpe>0.8?T.green:item.mcs.sharpe>0.3?T.amber:T.red):T.textMid}}>{item.mcs?item.mcs.sharpe.toFixed(2):"—"}</div></div>
                  <div style={{display:"flex",flexDirection:"column",gap:3,alignItems:"flex-end"}}>
                    {item.id===riskOptId&&<Badge label="RISK-ADJ ★" color={T.green}/>}
                    {item.id!==riskOptId&&<Badge label="SUB-OPT" color={T.textDim}/>}
                    <Badge label={item.p.marginPerMmbtu>0?"IN MONEY":"LOSS"} color={item.p.marginPerMmbtu>0?T.cyan:T.red}/>
                  </div>
                </div>
                {item.mcs&&<div style={{display:"flex",gap:8,marginTop:4,paddingTop:3,borderTop:`1px solid ${T.line}`,fontFamily:FM,fontSize:7.5,flexWrap:"wrap"}}><span style={{color:T.textDim}}>VaR95: <span style={{color:T.red}}>{fMa(item.mcs.var95)}</span></span><span style={{color:T.textDim}}>CVaR95: <span style={{color:T.redDim}}>{fMa(item.mcs.cvar95)}</span></span><span style={{color:T.textDim}}>BEP: <span style={{color:T.cyan}}>${f2(item.p.breakEvenDest)}</span></span></div>}
              </div>))}
              {mc&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:4}}>{[{l:"E[Margin]",v:fMa(mc.eu.mean),c:pColor(mc.eu.mean)},{l:"P(profit)",v:`${mc.eu.probP.toFixed(0)}%`,c:mc.eu.probP>60?T.green:T.red},{l:"FWD CURVE",v:curveLbl,c:curveCol}].map((s,i)=>(<div key={i} style={{background:T.bg2,padding:"5px 7px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>{s.l}</div><div style={{fontFamily:FM,fontSize:12,fontWeight:700,color:s.c}}>{s.v}</div></div>))}</div>}
              {kellySugg!==null&&mc&&mc.eu.mean>0&&<div style={{background:`${T.green}0A`,border:`1px solid ${T.green}33`,borderLeft:`2px solid ${T.green}`,padding:"5px 9px",borderRadius:2}}><div style={{fontFamily:FC,fontSize:8,color:T.green,letterSpacing:"0.12em",marginBottom:2}}>HALF-KELLY SIZE (EU)</div><div style={{fontFamily:FM,fontSize:10,color:T.text}}><span style={{color:T.green,fontSize:12,fontWeight:700}}>{kellySugg}%</span><span style={{color:T.textDim,fontSize:7,marginLeft:6}}>of capital · indicativo</span></div></div>}
            </div>
          </Card>
        </div>

        {/* ── ZONA 5: BREAK-EVEN MATRICES ─────────────────────────── */}
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5,marginBottom:6}}>
          <BreakEvenMatrixPanel params={params} hh={spx.hh} destUsd={ttfUsd} routeId="EU" destLabel="TTF$" routeLabel="HH × TTF  (EU / ROTTERDAM)" hfoPrice={hfoPrice}/>
          <BreakEvenMatrixPanel params={params} hh={spx.hh} destUsd={spx.jkm} routeId="AP" destLabel="JKM" routeLabel="HH × JKM  (AP / TOKYO)" hfoPrice={hfoPrice}/>
        </div>

        {/* ── FOOTER ──────────────────────────────────────────────── */}
        <div style={{borderTop:`1px solid ${T.line}`,paddingTop:6,display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:5}}>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>
            v7.1 · <span style={{color:T.green}}>HH: FRED/DHHNGSP · Brent: FRED/DCOILBRENTEU · FX: BCE · NG M1-M4: EIA/RNGC1-4</span>
            · <span style={{color:T.cyan}}>EU storage: GIE AGSI+ · EU LNG: GIE ALSI+</span>
            · <span style={{color:T.amber}}>HFO: Brent×6.80+115 ${hfoPrice.toFixed(0)}/MT · JKM: 3-regime proxy</span>
            · MC N={CFG.MC_N} seed · Student-t(ν=4) · CVaR · cubico fuel · regimeRef fix
          </div>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>
            <span style={{color:regimeInfo.color}}>● {regimeInfo.shortLabel}</span> · {new Date().toLocaleString("it-IT")} · #{tick}
          </div>
        </div>
      </div>
    </div>
  );
}}
