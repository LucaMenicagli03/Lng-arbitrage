                <div style={{fontFamily:FC,fontSize:17,fontWeight:800,color:T.green,lineHeight:1}}>
                  {optimal.label}
                  <span style={{fontSize:12,color:T.greenDim}}> ({optimal.dest})</span>
                  {stressMode&&<span style={{fontSize:9,color:SS[stressMode].color,marginLeft:7,fontFamily:FM}}>⚡ STRESS</span>}
                </div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:5,marginTop:6}}>
                  {[
                    {l:"MARGIN/MMBtu",v:`${optimal.p.marginPerMmbtu>=0?"+":""}$${f2(optimal.p.marginPerMmbtu)}`,c:pColor(optimal.p.marginPerMmbtu)},
                    {l:"TOTAL MARGIN",v:fM(optimal.p.marginTotal),c:pColor(optimal.p.marginTotal)},
                    {l:"TOTAL DAYS",  v:`${(optimal.p.td+optimal.p.ballastDays).toFixed(0)}d`,c:T.textMid},
                  ].map((s,i)=>(
                    <div key={i}>
                      <div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>{s.l}</div>
                      <div style={{fontFamily:FM,fontSize:12,fontWeight:700,color:s.c}}>{s.v}</div>
                    </div>
                  ))}
                </div>
              </div>

              {[
                {id:"EU",label:"Europa",   dest:"TTF",p:pEu,mcs:mc?.eu},
                {id:"AP",label:"Asia-Pac", dest:"JKM",p:pAp,mcs:mc?.ap},
              ].map(item=>(
                <div key={item.id} style={{background:T.bg2,padding:"6px 9px",borderRadius:2,
                  border:`1px solid ${item.id===rawOptId?T.green:T.line}`}}>
                  <div style={{display:"grid",gridTemplateColumns:"0.7fr 0.9fr 0.8fr 1fr",gap:4,alignItems:"center"}}>
                    <div>
                      <div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>ROTTA</div>
                      <div style={{fontFamily:FC,fontSize:12,fontWeight:700,color:item.id===rawOptId?T.green:T.text}}>
                        {item.dest}{item.id===rawOptId?" ★":""}
                      </div>
                    </div>
                    <div>
                      <div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>MARGIN/M</div>
                      <div style={{fontFamily:FM,fontSize:11,fontWeight:700,color:pColor(item.p.marginPerMmbtu)}}>
                        ${f2(item.p.marginPerMmbtu)}
                      </div>
                    </div>
                    <div>
                      <div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>SHARPE</div>
                      <div style={{fontFamily:FM,fontSize:11,fontWeight:700,
                        color:item.mcs?(item.mcs.sharpe>0.8?T.green:item.mcs.sharpe>0.3?T.amber:T.red):T.textMid}}>
                        {item.mcs?item.mcs.sharpe.toFixed(2):"—"}
                      </div>
                    </div>
                    <div style={{display:"flex",flexDirection:"column",gap:3,alignItems:"flex-end"}}>
                      {item.id===riskOptId&&<Badge label="RISK-ADJ ★" color={T.green}/>}
                      {item.id!==riskOptId&&<Badge label="SUB-OPT"   color={T.textDim}/>}
                      <Badge label={item.p.marginPerMmbtu>0?"IN MONEY":"LOSS"} color={item.p.marginPerMmbtu>0?T.cyan:T.red}/>
                    </div>
                  </div>
                  {item.mcs&&(
                    <div style={{display:"flex",gap:8,marginTop:4,paddingTop:3,
                      borderTop:`1px solid ${T.line}`,fontFamily:FM,fontSize:7.5,flexWrap:"wrap"}}>
                      <span style={{color:T.textDim}}>VaR95: <span style={{color:T.red}}>{fMa(item.mcs.var95)}</span></span>
                      <span style={{color:T.textDim}}>CVaR95: <span style={{color:"#CC0028"}}>{fMa(item.mcs.cvar95)}</span></span>
                      <span style={{color:T.textDim}}>BEP: <span style={{color:T.cyan}}>${f2(item.p.breakEvenDest)}</span></span>
                    </div>
                  )}
                </div>
              ))}

              {mc&&(
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:4}}>
                  {[
                    {l:"E[Margin]",  v:fMa(mc.eu.mean),            c:pColor(mc.eu.mean)},
                    {l:"P(profit)", v:`${mc.eu.probP.toFixed(0)}%`, c:mc.eu.probP>60?T.green:T.red},
                    {l:"FWD CURVE", v:curveLbl,                     c:curveCol},
                  ].map((s,i)=>(
                    <div key={i} style={{background:T.bg2,padding:"5px 7px",borderRadius:2}}>
                      <div style={{fontFamily:FC,fontSize:8,color:T.textMid}}>{s.l}</div>
                      <div style={{fontFamily:FM,fontSize:12,fontWeight:700,color:s.c}}>{s.v}</div>
                    </div>
                  ))}
                </div>
              )}
              {/* v6.0: Kelly position sizing hint */}
              {kellySuggestion !== null && mc && mc.eu.mean > 0 && (
                <div style={{background:`${T.teal}0A`,border:`1px solid ${T.teal}33`,
                  borderLeft:`2px solid ${T.teal}`,padding:"5px 9px",borderRadius:2}}>
                  <div style={{fontFamily:FC,fontSize:8,color:T.teal,letterSpacing:"0.12em",marginBottom:2}}>
                    HALF-KELLY POSITION SIZE (EU)
                  </div>
                  <div style={{fontFamily:FM,fontSize:10,color:T.text}}>
                    <span style={{color:T.teal,fontSize:12,fontWeight:700}}>{kellySuggestion}%</span>
                    <span style={{color:T.textDim,fontSize:7,marginLeft:6}}>
                      of capital · based on E[r]/σ² · indicative only
                    </span>
                  </div>
                </div>
              )}
            </div>
          </Card>
        </div>

        {/* ── ROW D: Break-Even Sensitivity Matrix v6.1 ─────────── */}
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5,marginBottom:6}}>
          <BreakEvenMatrixPanel
            params={params} hh={spx.hh} destUsd={ttfUsd}
            routeId="EU" destLabel="TTF$"
            routeLabel="HH × TTF  (EU / ROTTERDAM)"/>
          <BreakEvenMatrixPanel
            params={params} hh={spx.hh} destUsd={spx.jkm}
            routeId="AP" destLabel="JKM"
            routeLabel="HH × JKM  (AP / TOKYO)"/>
        </div>

        {/* ── FOOTER ────────────────────────────────────────────── */}
        <div style={{borderTop:`1px solid ${T.line}`,paddingTop:6,
          display:"flex",justifyContent:"space-between",alignItems:"center",
          flexWrap:"wrap",gap:5}}>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>
            SPA: HH×{params.spaSlope}+${params.sTolling}+${params.sLiquefaction}=<span style={{color:T.red}}>${pEu.acqPerMmbtu.toFixed(2)}/MMBtu</span>
            · Heel {params.heelM3}m³ · Sea {SEA_STATE[params.seaState]?.label} ×{SEA_STATE[params.seaState]?.mult}
            · Charter ×{(1+params.ballastFactor).toFixed(2)} (laden+ballast)
            · OU κ={OU_KAPPA} · Jump λ={params.lambdaJump} · Hawkes +60% · <span style={{color:T.teal}}>Student-t(ν=4) · CVaR · Charter ρ=0.65</span>
            {params.blPriceLocked&&<span style={{color:T.purple}}> · 🔒 B/L EU:${params.blPriceEU} AP:${params.blPriceAP}</span>}
            {params.suezWarActive&&<span style={{color:T.red}}> · WAR RISK ACTIVE</span>}
            {stressMode&&<span style={{color:SS[stressMode].color}}> · ⚡ {SS[stressMode].label}</span>}
          </div>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>
            <span style={{color:fxOk?T.green:T.amber}}>● </span>
            BCE/Frankfurter · OU+Merton JD · Hawkes · SPA · Dual-Fuel · VaR/CVaR · 2-State Regime · v6.0
          </div>
          <div style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>
            {new Date().toLocaleString("it-IT")} · #{tick} · <span style={{color:regimeInfo.color}}>{regimeInfo.shortLabel}</span>
          </div>
        </div>
      </div>
    </div>
  );
}
