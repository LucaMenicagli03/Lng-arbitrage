/* ═══════════════════════════════════════════════════════════════════════════
   COSTANTI FISICHE (fedeli al codice Python v2.0)
═══════════════════════════════════════════════════════════════════════════ */
const CAPACITY_M3   = 174_000;
const LNG_DENSITY   = 0.45;
const LNG_MMBTU_TON = 52.0;
const HFO_PRICE_USD = 480;
const HFO_E_MMBTU   = 40.5;
const SPEED_KNOTS   = 19.5;
const FUEL_DAY_MT   = 95;
const BOR_NOM       = 0.15 / 100;

const CAP_TONS  = CAPACITY_M3 * LNG_DENSITY;
const CAP_MMBTU = CAP_TONS * LNG_MMBTU_TON;

const ROUTES = [
  { id:"EU", label:"Europa",   dest:"TTF", nm:9_200,  regasFee:0.28, portO:280_000, portD:380_000, canal:0       },
  { id:"AP", label:"Asia-Pac", dest:"JKM", nm:16_100, regasFee:0.35, portO:280_000, portD:420_000, canal:500_000 },
];

function travelDays(nm) { return nm / (SPEED_KNOTS * 24); }

function calcProfit(hh, destUsd, charterRate, route) {
  const td       = travelDays(route.nm);
  const delivPct = Math.pow(1 - BOR_NOM, td);
  const deliv    = CAP_MMBTU * delivPct;
  const bog_mmbtu = CAP_MMBTU * (1 - delivPct);
  const hfo_cov  = bog_mmbtu / HFO_E_MMBTU;
  const net_hfo  = Math.max(0, FUEL_DAY_MT * td - hfo_cov);
  const fuel     = net_hfo * HFO_PRICE_USD;
  const supply   = CAP_MMBTU * hh;
  const charter  = charterRate * td;
  const regas    = deliv * route.regasFee;
  const ports    = route.portO + route.portD + route.canal;
  const revenue  = deliv * destUsd;
  const total    = supply + charter + fuel + regas + ports;
  return { profit:revenue-total, revenue, supply, charter, fuel, regas, ports, total, deliv, td };
}

/* ═══════════════════════════════════════════════════════════════════════════
   ORNSTEIN-UHLENBECK + CHOLESKY (replica RiskEngine Python v2.0)
   κ=0.15/anno | corr HH/TTF=0.65 | HH/JKM=0.55 | TTF/JKM=0.70
═══════════════════════════════════════════════════════════════════════════ */
const OU_KAPPA = 0.15;
const CORR_MAT = [[1.00,0.65,0.55],[0.65,1.00,0.70],[0.55,0.70,1.00]];

function choleskyL(C) {
  const n=C.length, L=Array.from({length:n},()=>Array(n).fill(0));
  for(let i=0;i<n;i++) for(let j=0;j<=i;j++){
    let s=C[i][j]; for(let k=0;k<j;k++) s-=L[i][k]*L[j][k];
    L[i][j]=j===i?Math.sqrt(Math.max(s,1e-14)):s/L[j][j];
  }
  return L;
}
const L_CHOL = choleskyL(CORR_MAT);

function randn() {
  let u=0,v=0;
  while(!u) u=Math.random(); while(!v) v=Math.random();
  return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);
}

const VOL_PRESETS = {
  low:    { hh:0.20, ttf:0.25, jkm:0.18 },
  normal: { hh:0.45, ttf:0.55, jkm:0.40 },
  high:   { hh:0.80, ttf:0.95, jkm:0.70 },
};

const MU = { hh:3.52, ttf:29.50, jkm:3.52*3.8+1.5 };

function ouStep(prices, vols, dt) {
  const z=[randn(),randn(),randn()];
  const zc=[
    L_CHOL[0][0]*z[0],
    L_CHOL[1][0]*z[0]+L_CHOL[1][1]*z[1],
    L_CHOL[2][0]*z[0]+L_CHOL[2][1]*z[1]+L_CHOL[2][2]*z[2],
  ];
  const floors=[0.30,5.0,6.0];
  return {
    hh:  Math.max(prices.hh +OU_KAPPA*(MU.hh -prices.hh )*dt+vols.hh *prices.hh *Math.sqrt(dt)*zc[0], floors[0]),
    ttf: Math.max(prices.ttf+OU_KAPPA*(MU.ttf-prices.ttf)*dt+vols.ttf*prices.ttf*Math.sqrt(dt)*zc[1], floors[1]),
    jkm: Math.max(prices.jkm+OU_KAPPA*(MU.jkm-prices.jkm)*dt+vols.jkm*prices.jkm*Math.sqrt(dt)*zc[2], floors[2]),
  };
}

function ttfToUsd(ttfEur, eurUsd) { return (ttfEur * eurUsd) / 3.41214; }

/* ─── Monte Carlo 500 sim ────────────────────────────────────────────── */
function runMC(hh, ttfUsd, jkm, charterRate, vols, N=500) {
  const profits = [];
  const dt = travelDays(ROUTES[0].nm)/365;
  for(let i=0;i<N;i++){
    const z=[randn(),randn(),randn()];
    const zc=[L_CHOL[0][0]*z[0],L_CHOL[1][0]*z[0]+L_CHOL[1][1]*z[1],L_CHOL[2][0]*z[0]+L_CHOL[2][1]*z[1]+L_CHOL[2][2]*z[2]];
    const hhS  = Math.max(hh   *(1+vols.hh *Math.sqrt(dt)*zc[0]),0.3);
    const ttfS = Math.max(ttfUsd*(1+vols.ttf*Math.sqrt(dt)*zc[1]),3.0);
    const delay= Math.max(0,Math.exp(randn()*0.5)-1);
    const td   = travelDays(ROUTES[0].nm)+delay;
    const deliv= CAP_MMBTU*Math.pow(1-BOR_NOM,td);
    const cr   = charterRate*(1+randn()*0.05);
    const bog  = CAP_MMBTU*(1-Math.pow(1-BOR_NOM,td));
    const fuel = Math.max(0,FUEL_DAY_MT*td-bog/HFO_E_MMBTU)*HFO_PRICE_USD;
    profits.push(deliv*ttfS - CAP_MMBTU*hhS - cr*td - fuel - deliv*0.28 - 660_000);
  }
  profits.sort((a,b)=>a-b);
  const mean=profits.reduce((s,v)=>s+v,0)/N;
  const std =Math.sqrt(profits.reduce((s,v)=>s+(v-mean)**2,0)/N);
  const var95=profits[Math.floor(N*0.05)];
  const var99=profits[Math.floor(N*0.01)];
  const probP=profits.filter(v=>v>0).length/N*100;
  const mn=profits[0], mx=profits[N-1], step=(mx-mn)/24;
  const bins=Array.from({length:24},(_,i)=>{
    const lo=mn+step*i, hi=lo+step;
    return {x:((lo+hi)/2/1e6).toFixed(2), n:profits.filter(v=>v>=lo&&v<hi).length, pos:(lo+hi)/2>0};
  });
  return {mean,std,var95,var99,probP,sharpe:mean/Math.max(std,1),bins,p5:profits[Math.floor(N*0.05)],p95:profits[Math.floor(N*0.95)]};
}

/* ═══════════════════════════════════════════════════════════════════════════
   FRANKFURTER API (BCE, gratuita, no-key, CORS OK)
   → EUR/USD reale aggiornato ogni 60 secondi
═══════════════════════════════════════════════════════════════════════════ */
async function fetchFX() {
  try {
    const r = await fetch("https://api.frankfurter.app/latest?from=EUR&to=USD,JPY",
      { signal: AbortSignal.timeout(7000) });
    if(!r.ok) throw new Error(r.status);
    const d = await r.json();
    return { eurUsd: d.rates.USD, usdJpy: d.rates.JPY / d.rates.USD };
  } catch { return null; }
}

