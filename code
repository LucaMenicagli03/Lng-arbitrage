/* ── Tornado ─────────────────────────────────────────────────────── */
function TornadoChart({data}){
  if(!data?.length)return null;
  return(<ResponsiveContainer width="100%" height={158}>
    <BarChart data={data} layout="vertical" margin={{top:2,right:28,bottom:0,left:90}}>
      <CartesianGrid stroke={T.line} strokeDasharray="2 4" horizontal={false}/>
      <XAxis type="number" tick={{fill:T.textDim,fontSize:7,fontFamily:FM}} tickFormatter={v=>`${v>0?"+":""}${v.toFixed(1)}%`} domain={["dataMin - 0.5","dataMax + 0.5"]}/>
      <YAxis type="category" dataKey="subject" width={88} tick={{fill:T.textMid,fontSize:8,fontFamily:FC,fontWeight:700}}/>
      <ReferenceLine x={0} stroke="rgba(255,255,255,0.2)" strokeDasharray="3 2"/>
      <Tooltip content={<Tip pre="" dec={2}/>}/>
      <Bar dataKey="upside"   name="+1% Δ%" fill={`${T.green}BB`} isAnimationActive={false} radius={[0,2,2,0]}/>
      <Bar dataKey="downside" name="-1% Δ%" fill={`${T.red}BB`}   isAnimationActive={false} radius={[0,2,2,0]}/>
    </BarChart>
  </ResponsiveContainer>);
}

/* ── Break-Even Matrix ───────────────────────────────────────────── */
function matCell(m){
  if(m>= 2.0)return{bg:"#0A2818",fg:"#5ED49A",bz:false};
  if(m>= 1.0)return{bg:"#0E3820",fg:"#4AC082",bz:false};
  if(m>= 0.15)return{bg:"#163A26",fg:"#70C898",bz:false};
  if(m>= 0.0)return{bg:"#1C3028",fg:"#5BAE82",bz:true};
  if(m>=-0.15)return{bg:"#301C20",fg:"#C07878",bz:true};
  if(m>=-1.0)return{bg:"#4A1E28",fg:"#C89090",bz:false};
  if(m>=-2.0)return{bg:"#6A2030",fg:"#D4A0A8",bz:false};
  return{bg:"#501428",fg:"#DEB8C0",bz:false};
}
function BreakEvenMatrixPanel({params,hh,destUsd,routeId,destLabel,routeLabel,hfoPrice}){
  const[hoveredCell,setHoveredCell]=useState(null);
  const{hhSteps,destSteps,matrix,dstDelta,bepCenter}=useMemo(()=>calcBreakEvenMatrix(params,hh,destUsd,routeId,hfoPrice),[params,hh,destUsd,routeId,hfoPrice]);
  const CR=Math.floor(hhSteps.length/2),CC=Math.floor(destSteps.length/2);
  const ctrCell=(matrix[CR]||[])[CC]||{margin:0,bep:0,acq:0};
  const pctStr=(val,ref)=>{const d=(val-ref)/ref*100;return(d>=0?"+":"")+d.toFixed(0)+"%";};
  const accent=routeId==="EU"?T.cyan:T.amber;
  return(<Card accent={accent} style={{overflow:"hidden"}}>
    <div style={{marginBottom:7,paddingBottom:6,borderBottom:`1px solid ${T.line}`}}>
      <div style={{fontFamily:FC,fontSize:12,fontWeight:800,color:accent,letterSpacing:"0.1em",textTransform:"uppercase"}}>MARGIN MATRIX — {routeLabel}</div>
      <div style={{display:"flex",gap:14,marginTop:5,fontFamily:FM,fontSize:8,flexWrap:"wrap"}}>
        <span style={{color:T.textDim}}>HH: <span style={{color:T.green,fontWeight:700}}>${f3(hh)}</span> ±20%</span>
        <span style={{color:T.textDim}}>{destLabel}: <span style={{color:accent,fontWeight:700}}>${f3(destUsd)}</span> <span style={{color:T.amber}}>−{f1(dstDelta/destUsd*100)}%/+{f1(dstDelta/destUsd*100)}%</span> <span style={{color:T.textDim,fontSize:7}}>(dyn)</span></span>
        <span style={{color:T.textDim}}>Margin: <span style={{color:ctrCell.margin>=0?T.green:T.red,fontWeight:700}}>{ctrCell.margin>=0?"+":""}{f2(ctrCell.margin)}/M</span></span>
        <span style={{color:T.textDim}}>BEP: <span style={{color:T.teal,fontWeight:700}}>${f2(bepCenter)}</span></span>
      </div>
    </div>
    <div style={{minHeight:24,marginBottom:5,padding:"3px 8px",borderRadius:2,background:hoveredCell?T.bg2:"transparent",border:hoveredCell?`1px solid ${T.line2}`:`1px solid transparent`,fontFamily:FM,fontSize:8,display:"flex",gap:12,flexWrap:"wrap",alignItems:"center"}}>
      {hoveredCell?(<>
        <span>HH <span style={{color:T.green,fontWeight:700}}>${f3(hoveredCell.h)}</span> ({pctStr(hoveredCell.h,hh)})</span>
        <span>{destLabel} <span style={{color:accent,fontWeight:700}}>${f3(hoveredCell.d)}</span> ({pctStr(hoveredCell.d,destUsd)})</span>
        <span>Margin <span style={{color:hoveredCell.margin>=0?T.green:T.red,fontWeight:700}}>{hoveredCell.margin>=0?"+":""}{f2(hoveredCell.margin)}/M</span></span>
        <span style={{color:T.textDim}}>BEP: <span style={{color:T.amber}}>${f2(hoveredCell.bep)}</span></span>
      </>):(<span style={{color:T.textDim,fontSize:7}}>hover per breakdown completo</span>)}
    </div>
    <div style={{overflowX:"auto"}}>
      <table style={{borderCollapse:"separate",borderSpacing:"2px",fontFamily:FM,width:"100%",minWidth:460}}>
        <thead>
          <tr><td style={{padding:"0 0 2px 0"}}/><td colSpan={destSteps.length} style={{fontFamily:FC,fontSize:8,fontWeight:700,color:accent,letterSpacing:"0.12em",textAlign:"center",paddingBottom:2}}>{"← "+destLabel+" DESTINATION PRICE ($/MMBtu) →"}</td></tr>
          <tr>
            <td style={{padding:"3px 4px",textAlign:"center",background:T.bg2,borderRadius:2,fontFamily:FC,fontSize:7,color:T.textDim,border:`1px solid ${T.line}`,verticalAlign:"bottom",whiteSpace:"nowrap"}}>HH↓/{destLabel}→</td>
            {destSteps.map((d,j)=>{const isCC=j===CC;return(<td key={j} style={{textAlign:"center",padding:"3px 2px",background:isCC?accent+"25":T.bg2,border:isCC?`2px solid ${accent}`:`1px solid ${T.line}`,borderRadius:2}}>
              <div style={{fontFamily:FM,fontSize:9,fontWeight:isCC?800:500,color:isCC?accent:T.textMid,lineHeight:1.2}}>${f2(d)}</div>
              <div style={{fontFamily:FC,fontSize:7,color:isCC?accent:(d>destUsd?T.green:T.red),lineHeight:1.2}}>{isCC?"LIVE":pctStr(d,destUsd)}</div>
            </td>);})}
          </tr>
        </thead>
        <tbody>
          {hhSteps.map((h,i)=>{
            const isCR=i===CR,cells=matrix[i]||[];
            return(<tr key={i}>
              <td style={{padding:"2px 5px",textAlign:"right",background:isCR?T.green+"20":T.bg2,border:isCR?`2px solid ${T.green}`:`1px solid ${T.line}`,borderRadius:2,whiteSpace:"nowrap"}}>
                <div style={{fontFamily:FM,fontSize:9,fontWeight:isCR?800:500,color:isCR?T.green:T.textMid,lineHeight:1.2}}>${f2(h)}</div>
                <div style={{fontFamily:FC,fontSize:7,color:isCR?T.green:(h<hh?T.green:T.red),lineHeight:1.2}}>{isCR?"LIVE":pctStr(h,hh)}</div>
              </td>
              {destSteps.map((d,j)=>{
                const cell=cells[j]||{margin:0,bep:0,acq:0};
                const{bg,fg,bz}=matCell(cell.margin);
                const isCurCell=(i===CR&&j===CC);
                return(<td key={j} onMouseEnter={()=>setHoveredCell({h,d,margin:cell.margin,bep:cell.bep,acq:cell.acq})} onMouseLeave={()=>setHoveredCell(null)} style={{background:bg,textAlign:"center",padding:isCurCell?"7px 3px":"5px 3px",borderRadius:2,cursor:"default",border:isCurCell?`2px solid ${T.cyan}`:bz?`1px solid ${T.teal}`:(j===CC||isCR)?`1px solid rgba(255,255,255,0.14)`:`1px solid rgba(0,0,0,0.5)`,boxShadow:isCurCell?`0 0 6px ${T.cyan}70`:"none",opacity:(!isCR&&j!==CC)?0.84:1}}>
                  <div style={{fontFamily:FM,fontSize:isCurCell?11:9,fontWeight:700,color:fg,lineHeight:1,letterSpacing:"-0.01em"}}>{isCurCell?"★ "+(cell.margin>=0?"+":"")+f2(cell.margin):bz?"~ "+(cell.margin>=0?"+":"")+f2(cell.margin):(cell.margin>=0?"+":"")+f2(cell.margin)}</div>
                </td>);
              })}
            </tr>);
          })}
        </tbody>
      </table>
    </div>
    <div style={{display:"flex",alignItems:"center",gap:3,marginTop:6,paddingTop:4,borderTop:`1px solid ${T.line}`,flexWrap:"wrap"}}>
      <span style={{fontFamily:FC,fontSize:7.5,color:T.textDim,marginRight:3}}>SCALA:</span>
      {[{l:"-$2+",bg:"#501428",fg:"#DEB8C0"},{l:"-$1",bg:"#6A2030",fg:"#D4A0A8"},{l:"~BEP",bg:"#301C20",fg:"#C07878",bdr:T.teal},{l:"~BEP",bg:"#1C3028",fg:"#5BAE82",bdr:T.teal},{l:"+$1",bg:"#0E3820",fg:"#4AC082"},{l:"+$2+",bg:"#0A2818",fg:"#5ED49A"}].map((s,i)=>(
        <div key={i} style={{background:s.bg,color:s.fg,border:s.bdr?`1px solid ${s.bdr}`:`1px solid rgba(255,255,255,0.08)`,padding:"2px 6px",borderRadius:2,fontFamily:FM,fontSize:7.5,fontWeight:700,whiteSpace:"nowrap"}}>{s.l}</div>
      ))}
    </div>
  </Card>);
}

/* ── Margin Panel ────────────────────────────────────────────────── */
function MarginPanel({pEu,pAp,ttfUsd,jkm,params,dqTtf,dqJkm}){
  const routes=[
    {id:"EU",label:"EU / TTF",p:pEu,mkt:ttfUsd,color:T.cyan,  dest:"Rotterdam",alertThr:params.alertThresholdEU,dq:dqTtf},
    {id:"AP",label:"AP / JKM",p:pAp,mkt:jkm,   color:T.amber, dest:"Tokyo",    alertThr:params.alertThresholdAP,dq:dqJkm},
  ];
  return(<Card accent={T.green}>
    <SH label="Margin over Break-even" right="$/MMBtu · Primary KPI" accent={T.green}/>
    <div style={{background:T.bg2,border:`1px solid ${T.line}`,borderLeft:`2px solid ${T.amber}`,padding:"6px 9px",borderRadius:2,marginBottom:7}}>
      <div style={{fontFamily:FC,fontSize:9,fontWeight:700,color:T.amber,letterSpacing:"0.14em",marginBottom:4}}>SPA ACQUISITION COST</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:5}}>
        {[{l:"HH Spot",v:`$${f3(pEu.hhInput??0)}`,c:T.cyan},{l:"×Slope",v:`×${params.spaSlope.toFixed(3)}`,c:T.textMid},{l:"+Tolling",v:`+$${params.sTolling.toFixed(2)}`,c:T.amber},{l:"ACQ COST",v:`$${pEu.acqPerMmbtu.toFixed(3)}/M`,c:T.red}].map((s,i)=>(
          <div key={i}><div style={{fontFamily:FC,fontSize:8,color:T.textDim}}>{s.l}</div><div style={{fontFamily:FM,fontSize:11,fontWeight:700,color:s.c}}>{s.v}</div></div>
        ))}
      </div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5}}>
      {routes.map(r=>{
        const inMoney=r.p.marginPerMmbtu>0,belowAlert=r.p.marginPerMmbtu<r.alertThr&&r.p.marginPerMmbtu>=0;
        const marginPct=r.p.breakEvenDest>0?((r.mkt-r.p.breakEvenDest)/r.p.breakEvenDest*100):0;
        const borderColor=belowAlert?T.amber:inMoney?r.color:T.red;
        return(<div key={r.id} style={{background:T.bg2,padding:"7px 9px",borderRadius:2,border:`1px solid ${borderColor}`,borderLeft:`3px solid ${borderColor}`,boxShadow:belowAlert?`0 0 8px ${T.amber}44`:"none"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5}}>
            <div style={{fontFamily:FC,fontSize:10,fontWeight:700,color:r.color,letterSpacing:"0.12em"}}>{r.label} · {r.dest}</div>
            <DQBadge level={r.dq} compact/>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:4}}>
            {[
              {l:"Market",       v:`$${f3(r.mkt)}`,                                          c:r.color},
              {l:"Break-even",   v:`$${f3(r.p.breakEvenDest)}`,                              c:T.textMid},
              {l:"Margin/MMBtu", v:`${r.p.marginPerMmbtu>=0?"+":""}$${f2(r.p.marginPerMmbtu)}`,c:inMoney?T.green:T.red},
              {l:"Total Margin", v:fM(r.p.marginTotal),                                      c:inMoney?T.green:T.red},
              {l:"Margin %",     v:`${marginPct>=0?"+":""}${marginPct.toFixed(1)}%`,          c:inMoney?T.green:T.red},
              {l:"Deliver",      v:`${(r.p.deliv/1e6).toFixed(1)}M MMBtu`,                   c:T.textMid},
            ].map((s,i)=>(<div key={i}><div style={{fontFamily:FC,fontSize:8,color:T.textDim}}>{s.l}</div><div style={{fontFamily:FM,fontSize:10,fontWeight:700,color:s.c}}>{s.v}</div></div>))}
          </div>
          <div style={{marginTop:5,background:T.bg0,borderRadius:2,height:6,overflow:"hidden"}}>
            <div style={{height:"100%",borderRadius:2,transition:"width 0.4s",background:inMoney?r.color:T.red,width:`${Math.min(100,Math.max(0,(r.mkt/Math.max(r.p.breakEvenDest,0.1))*60))}%`}}/>
          </div>
        </div>);
      })}
    </div>
  </Card>);
}

/* ── Sidebar ──────────────────────────────────────────────────────── */
