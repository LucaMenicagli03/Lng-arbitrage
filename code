      <Sec title="Vessel & Sea State" accent={T.cyan}>
        <Param label="CAPACITY" value={params.capacityM3} min={140000} max={210000} step={1000} onChange={v=>onUpdate("capacityM3",v)} unit="m³" prec={0}/>
        <Param label="HEEL" value={params.heelM3} min={500} max={4000} step={100} onChange={v=>onUpdate("heelM3",v)} unit="m³" prec={0} color={T.textMid}/>
        <Param label="BOIL-OFF RATE" value={params.borRate} min={0.05} max={0.30} step={0.01} onChange={v=>onUpdate("borRate",v)} unit="%/day" prec={2} color={T.amber}/>
        <Param label="SPEED" value={params.speedKnots} min={14} max={22} step={0.5} onChange={v=>onUpdate("speedKnots",v)} unit="kn" prec={1} note={`Fuel cubico: ${fuelPerDay(params.speedKnots).toFixed(1)} MT/d`}/>
        <div style={{marginBottom:9}}>
          <div style={{fontFamily:FC,fontSize:9,color:T.textMid,letterSpacing:"0.1em",marginBottom:4}}>SEA STATE</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:3}}>
            {Object.entries(SEA_STATE).map(([k,s])=>{const active=params.seaState===k;return(<button key={k} onClick={()=>onUpdate("seaState",k)} style={{fontFamily:FC,fontSize:9,fontWeight:700,cursor:"pointer",borderRadius:2,padding:"5px 6px",textAlign:"left",border:`1px solid ${active?(k==="storm"?T.red:k==="rough"?T.amber:T.cyan):T.line}`,background:active?`${k==="storm"?T.red:k==="rough"?T.amber:T.cyan}20`:T.bg2,color:active?T.text:T.textDim}}><div style={{letterSpacing:"0.1em"}}>{s.label}</div><div style={{fontFamily:FM,fontSize:7,color:T.textDim,fontWeight:400}}>×{s.mult.toFixed(2)} BOR</div></button>);})}
          </div>
        </div>
      </Sec>
      <Sec title="Charter & Capital" accent={T.amber}>
        <Param label="CHARTER RATE" value={params.charterRate} min={40000} max={500000} step={5000} onChange={v=>onUpdate("charterRate",v)} unit="$/day" prec={0} color={T.green}/>
        <Param label="BALLAST FACTOR" value={params.ballastFactor} min={0.50} max={1.20} step={0.05} onChange={v=>onUpdate("ballastFactor",v)} unit="× laden" prec={2} color={T.amber}/>
        <Param label="SOFR RATE" value={params.sofr} min={0.0} max={12.0} step={0.10} onChange={v=>onUpdate("sofr",v)} unit="%" prec={2} color={T.amberDim}/>
      </Sec>
      <Sec title="Routing" accent={T.amberDim}>
        <Toggle label="CAPE OF GOOD HOPE" value={params.useCape} onChange={v=>onUpdate("useCape",v)} note={`+${(NM.AP_CAPE-NM.AP_SUEZ).toLocaleString()}nm`}/>
        <Toggle label="SUEZ WAR RISK" value={params.suezWarActive} onChange={v=>onUpdate("suezWarActive",v)} color={T.red} note={`+${fDol(params.warRiskSuez)}`}/>
        <Param label="SUEZ CANAL FEE" value={params.canalAP} min={0} max={1200000} step={10000} onChange={v=>onUpdate("canalAP",v)} unit="$" prec={0} color={T.amber}/>
        <Param label="DIVERSION PENALTY" value={params.diversionPenalty} min={0} max={3000000} step={50000} onChange={v=>onUpdate("diversionPenalty",v)} unit="$" prec={0} color={T.amber}/>
      </Sec>
      <Sec title="Fees & Thresholds" accent={T.amberDim}>
        <Param label="PORT ORIGIN" value={params.portOrigin} min={100000} max={600000} step={5000} onChange={v=>onUpdate("portOrigin",v)} unit="$" prec={0} color={T.textMid}/>
        <Param label="PORT DEST" value={params.portDest} min={100000} max={700000} step={5000} onChange={v=>onUpdate("portDest",v)} unit="$" prec={0} color={T.textMid}/>
        <Param label="REGAS EU" value={params.regasFeeEU} min={0.10} max={0.80} step={0.01} onChange={v=>onUpdate("regasFeeEU",v)} unit="$/MMBtu" prec={2}/>
        <Param label="REGAS AP" value={params.regasFeeAP} min={0.10} max={0.80} step={0.01} onChange={v=>onUpdate("regasFeeAP",v)} unit="$/MMBtu" prec={2} color={T.amber}/>
        <Param label="ALERT EU" value={params.alertThresholdEU} min={0} max={2.0} step={0.05} onChange={v=>onUpdate("alertThresholdEU",v)} unit="$/MMBtu" prec={2} color={T.amber}/>
        <Param label="ALERT AP" value={params.alertThresholdAP} min={0} max={2.0} step={0.05} onChange={v=>onUpdate("alertThresholdAP",v)} unit="$/MMBtu" prec={2} color={T.amber}/>
      </Sec>
      <Sec title="B/L Price Lock" accent={T.amber}>
        <Toggle label="B/L PRICE LOCK" value={params.blPriceLocked} onChange={v=>onUpdate("blPriceLocked",v)} color={T.amber}/>
        {params.blPriceLocked&&(<>
          <Param label="B/L EU" value={params.blPriceEU||10} min={3} max={40} step={0.10} onChange={v=>onUpdate("blPriceEU",v)} unit="$/M" prec={2} color={T.amber}/>
          <Param label="B/L AP" value={params.blPriceAP||12} min={3} max={50} step={0.10} onChange={v=>onUpdate("blPriceAP",v)} unit="$/M" prec={2} color={T.amber}/>
        </>)}
      </Sec>
      <Sec title="Jump Diffusion" accent={T.red}>
        <Param label="λ INTENSITY" value={params.lambdaJump} min={0} max={4} step={0.1} onChange={v=>onUpdate("lambdaJump",v)} unit="/yr" prec={1} color={T.red}/>
        <Param label="σ JUMP SIZE" value={params.sigmaJump} min={0.05} max={1.0} step={0.05} onChange={v=>onUpdate("sigmaJump",v)} unit="σ" prec={2} color={T.redDim}/>
      </Sec>
      <button onClick={()=>onUpdate("__RESET__",null)} style={{width:"100%",fontFamily:FC,fontSize:10,fontWeight:700,letterSpacing:"0.14em",color:T.textMid,background:"transparent",border:`1px solid ${T.line2}`,borderRadius:2,padding:"7px",cursor:"pointer",textTransform:"uppercase",marginTop:6}}>↺ RESET DEFAULTS</button>
    </div>
  </>);
}

/* ════════════════════════════════════════════════════════════════════════
   MAIN DASHBOARD
════════════════════════════════════════════════════════════════════════ */
export default function LNGDashboard(){
  const[params,setParams]=useState(DP);
  const[px,setPx]=useState({hh:3.52,ttf:29.50,jkm:14.98,eurUsd:1.085,usdJpy:149.5});
  const[prevPx,setPrevPx]=useState(null);
  const[realPrices,setRealPrices]=useState({hh:null,brent:null,hfo:null,jkm:null,eurUsd:null,futures:null,agsi:null,alsi:null,hhDq:"SIM",brentDq:"SIM",fxDq:"SIM",futuresDq:"SIM",agsiDq:"SIM",alsiDq:"SIM"});
  const[storage,setStorage]=useState(null);
  const[lngExports,setLngExports]=useState(null);
  const[history,setHistory]=useState([]);
  const[marginH,setMarginH]=useState([]);
  const[spreadH,setSpreadH]=useState([]);
  const[mc,setMc]=useState(null);
  const[mcSeed,setMcSeed]=useState(42);
  const[volMode,setVolMode]=useState("normal");
  const[isLive,setIsLive]=useState(true);
  const[tick,setTick]=useState(0);
  const[stressMode,setStressMode]=useState(null);
  const[sidebarOpen,setSidebarOpen]=useState(false);
  const[regime,setRegime]=useState("normal");
  const[fwdSeeds,setFwdSeeds]=useState(()=>Array.from({length:12},()=>[randn(),randn(),randn()]));
  const[fxAge,setFxAge]=useState(0);
  const[dataLoadTs,setDataLoadTs]=useState(null);
  const tickRef=useRef(0), intRef=useRef(null), regimeRef=useRef("normal");
  const updateParam=useCallback((key,val)=>{if(key==="__RESET__"){setParams(DP);return;}setParams(p=>({...p,[key]:val}));},[]);

  /* ── Master data fetch — tutte le fonti in parallelo ─────────── */
  const doRealFetch=useCallback(async()=>{
    // FASE 1: FRED + BCE + EIA futures + TTF proxy — tutti in parallelo
    const[hhR,brentR,fxR,futR,ttfR]=await Promise.all([
      fetchFRED("DHHNGSP"), fetchFRED("DCOILBRENTEU"), fetchBCE(),
      fetchEIAFutures(), fetchTTFProxy(),
    ]);
    const newHH=hhR?.value??null, newBrent=brentR?.value??null;
    const newHFO=newBrent?hfoFromBrent(newBrent):null;
    const newJKM=(newHH&&newBrent)?jkmProxy(newHH,newBrent):null;
    const newEurUsd=fxR?.eurUsd??null;
    // TTF in €/MWh — dato reale via CF Worker (era SIM in v7.0)
    const newTTFraw=ttfR?.value??null;
    // FASE 2: AGSI/ALSI — GIE API (possono avere latenza maggiore)
    const[agsiR,alsiR]=await Promise.all([fetchAGSI(),fetchALSI()]);
    setRealPrices(prev=>({
      ...prev,
      hh:newHH??prev.hh, brent:newBrent??prev.brent,
      hfo:newHFO??prev.hfo, jkm:newJKM??prev.jkm,
      eurUsd:newEurUsd??prev.eurUsd,
      ttfRaw:newTTFraw??prev.ttfRaw,
      futures:futR??prev.futures,
      agsi:agsiR??prev.agsi,
      alsi:alsiR??prev.alsi,
      hhDq:newHH?"LIVE":"SIM",
      brentDq:newBrent?"LIVE":"SIM",
      fxDq:newEurUsd?"LIVE":"SIM",
      ttfDq:newTTFraw?"PROXY":"SIM",      // PROXY = CF Worker funzionante
      futuresDq:futR?"LIVE":"SIM",
      agsiDq:agsiR?"LIVE":"SIM",
      alsiDq:alsiR?"LIVE":"SIM",
    }));
    // Ancora il simulatore OU ai prezzi reali (TTF incluso ora)
    if(newHH||newJKM||newEurUsd||newTTFraw)
      setPx(prev=>({
        ...prev,
        hh:     newHH??prev.hh,
        ttf:    newTTFraw??prev.ttf,   // ← TTF reale come seed OU
        jkm:    newJKM??prev.jkm,
        eurUsd: newEurUsd??prev.eurUsd,
      }));
    setDataLoadTs(new Date().toLocaleTimeString("it-IT",{hour:"2-digit",minute:"2-digit"}));
  },[]);

  const doStorageFetch=useCallback(async()=>{
    const[storR,expR]=await Promise.all([fetchEIAStorage(),fetchEIALngExports()]);
    if(storR)setStorage(storR);
    if(expR)setLngExports(expR);
  },[]);

  /* ── Init ───────────────────────────────────────────────────────── */
  useEffect(()=>{
    const vols=CFG.VOL.normal;
    let s={hh:3.52,ttf:29.50,jkm:14.98,eurUsd:1.085,usdJpy:149.5};
    const anchor={...s};
    const h=[],mh=[],sh=[];
    for(let i=85;i>=0;i--){
      const ns=ouStep(s,anchor,vols,1/365/24,"normal");
      s={...ns,eurUsd:s.eurUsd,usdJpy:s.usdJpy};
      const ttfU=ttfToUsd(s.ttf,s.eurUsd);
      const t=new Date(Date.now()-i*2000).toLocaleTimeString("it-IT",{hour:"2-digit",minute:"2-digit",second:"2-digit"});
      h.push({t,hh:s.hh,ttf:ttfU,jkm:s.jkm}); sh.push({t,eu:ttfU-s.hh,ap:s.jkm-s.hh});
      const pE=calcProfit(s.hh,ttfU,DP,"EU",CFG.HFO_FALLBACK),pA=calcProfit(s.hh,s.jkm,DP,"AP",CFG.HFO_FALLBACK);
      mh.push({t,eu:pE.marginPerMmbtu,ap:pA.marginPerMmbtu});
    }
    setHistory(h);setSpreadH(sh);setMarginH(mh);
    doRealFetch(); doStorageFetch();
    const fredInt=setInterval(doRealFetch,4*60*60*1000);
    const storInt=setInterval(doStorageFetch,6*60*60*1000);
    const ageInt =setInterval(()=>setFxAge(a=>a+1),1000);
    return()=>{clearInterval(fredInt);clearInterval(storInt);clearInterval(ageInt);};
  },[]);// eslint-disable-line

  /* ── Tick engine ────────────────────────────────────────────────── */
  const doTick=useCallback(()=>{
    const vols=CFG.VOL[volMode];
    setPx(prev=>{
      setPrevPx({...prev});
      const curRegime=regimeRef.current;
      const reg=REGIME[curRegime];
      const nextRegime=Math.random()<reg.pTransition?(curRegime==="normal"?"crisis":"normal"):curRegime;
      regimeRef.current=nextRegime; setRegime(nextRegime);
      const anchor={
        hh:  realPrices.hh??prev.hh,
        // FIX v7.2: ttfRaw è in €/MWh (da CF Worker) — unità corretta per OU TTF
        // v7.1 aveva RNGC1 (HH futures $/MMBtu) come anchor TTF → unità sbagliate
        ttf: realPrices.ttfRaw??prev.ttf,
        jkm: realPrices.jkm??prev.jkm,
      };
      const ns=ouStep(prev,anchor,vols,1/365/24,curRegime);
      ns.eurUsd=prev.eurUsd; ns.usdJpy=prev.usdJpy;
      const ttfU=ttfToUsd(ns.ttf,ns.eurUsd);
      const now=ts(), hfo=realPrices.hfo??CFG.HFO_FALLBACK;
      setHistory(h=>[...h.slice(-89),{t:now,hh:ns.hh,ttf:ttfU,jkm:ns.jkm}]);
      setSpreadH(h=>[...h.slice(-89),{t:now,eu:ttfU-ns.hh,ap:ns.jkm-ns.hh}]);
      const pE=calcProfit(ns.hh,ttfU,params,"EU",hfo),pA=calcProfit(ns.hh,ns.jkm,params,"AP",hfo);
      setMarginH(h=>[...h.slice(-89),{t:now,eu:pE.marginPerMmbtu,ap:pA.marginPerMmbtu}]);
      tickRef.current++;
      if(tickRef.current%30===0)setFwdSeeds(Array.from({length:12},()=>[randn(),randn(),randn()]));
      if(tickRef.current%12===0){
        const seed=Date.now()%999983;
        setMcSeed(seed);
        setMc(runMC(ns.hh,ttfU,ns.jkm,params,vols,hfo,stressMode,nextRegime,seed));
      }
      setTick(tickRef.current);
      return ns;
    });
  },[volMode,params,stressMode,realPrices]);

  useEffect(()=>{
    if(isLive){intRef.current=setInterval(doTick,2000);}
    else clearInterval(intRef.current);
    return()=>clearInterval(intRef.current);
  },[isLive,doTick]);

  /* ── Derived ────────────────────────────────────────────────────── */
  const hfoPrice=realPrices.hfo??CFG.HFO_FALLBACK;
  const spx=useMemo(()=>{
    if(!stressMode)return px;
    const s=SS[stressMode];
    return{...px,hh:px.hh*s.mHH,ttf:px.ttf*s.mTTF,jkm:px.jkm*s.mJKM};
  },[px,stressMode]);
  const ttfUsd=ttfToUsd(spx.ttf,spx.eurUsd);
  const pEu=calcProfit(spx.hh,ttfUsd,params,"EU",hfoPrice);
  const pAp=calcProfit(spx.hh,spx.jkm,params,"AP",hfoPrice);
  const prevTtfUsd=prevPx?ttfToUsd(prevPx.ttf,prevPx.eurUsd):ttfUsd;
  const rawOptId=pEu.marginTotal>=pAp.marginTotal?"EU":"AP";
  const riskOptId=(mc?.eu?.sharpe??0)>=(mc?.ap?.sharpe??0)?"EU":"AP";
  const conflict=rawOptId!==riskOptId;
  const optimal=rawOptId==="EU"?{id:"EU",label:"Europa",dest:"TTF",p:pEu}:{id:"AP",label:"Asia-Pac",dest:"JKM",p:pAp};
  const rte=useMemo(()=>calcRouteBreakeven(spx.hh,spx.jkm,params,hfoPrice),[spx.hh,spx.jkm,params,hfoPrice]);
  const div=useMemo(()=>calcCargoDiversion(spx.hh,ttfUsd,spx.jkm,params,hfoPrice,0.5),[spx.hh,ttfUsd,spx.jkm,params,hfoPrice]);
  const sensi=useMemo(()=>Array.from({length:22},(_,i)=>{const cr=40_000+i*5_000,res=calcProfit(spx.hh,ttfUsd,{...params,charterRate:cr},"EU",hfoPrice);return{cr:cr/1000,margin:res.marginPerMmbtu,profit:res.profit/1e6};}),[spx.hh,ttfUsd,params,hfoPrice]);
  const spider=useMemo(()=>calcSpider(params,spx.hh,ttfUsd,spx.jkm,hfoPrice),[params,spx.hh,spx.jkm,ttfUsd,hfoPrice]);
  const boiloff=useMemo(()=>{
    const seaMult=SEA_STATE[params.seaState]?.mult??1.0,borNom=params.borRate/100;
    const borLo=borNom*SEA_STATE.calm.mult,borNm=borNom*seaMult,borHi=borNom*SEA_STATE.storm.mult;
    return Array.from({length:30},(_,i)=>({d:i+1,lo:Math.pow(1-borLo,i+1)*100,nm:Math.pow(1-borNm,i+1)*100,hi:Math.pow(1-borHi,i+1)*100}));
  },[params.borRate,params.seaState]);

  /* ── Forward curve v7.1 — M1-M4 EIA reali + M5-M12 OU ────────── */
  const fwd=useMemo(()=>{
    const fut=realPrices.futures;
    return fwdSeeds.map((z,i)=>{
      const t=(i+1)/12;
      const ancHH=realPrices.hh??spx.hh, ancJKM=realPrices.jkm??spx.jkm;
      // M1-M4: usa EIA futures reali per HH se disponibili
      let hhFwd;
      if(fut&&i<4){
        const key=["RNGC1","RNGC2","RNGC3","RNGC4"][i];
        hhFwd=fut[key]?.price??Math.max(0.30,spx.hh+(ancHH-spx.hh)*CFG.OU_KAPPA*t+z[0]*0.02);
      } else {
        hhFwd=Math.max(0.30,spx.hh+(ancHH-spx.hh)*CFG.OU_KAPPA*t+z[0]*0.02);
      }
      return{
        m:`M${i+1}`,
        hh:hhFwd,
        real:i<4&&fut?1:0, // flag: 1=EIA real, 0=OU sim
        ttf:Math.max(3.00,ttfUsd+(ttfUsd-ttfUsd)*CFG.OU_KAPPA*t*0.4+z[1]*0.12),
        jkm:Math.max(5.00,spx.jkm+(ancJKM-spx.jkm)*CFG.OU_KAPPA*t+z[2]*0.08),
      };
    });
  },[fwdSeeds,spx.hh,spx.jkm,ttfUsd,realPrices.hh,realPrices.jkm,realPrices.futures]);

  const fwdSlope=fwd.length>1?fwd[11].ttf-fwd[0].ttf:0;
  const curveLbl=fwdSlope>0.5?"CONTANGO":fwdSlope<-0.5?"BACKWARDATION":"FLAT";
  const curveCol=curveLbl==="CONTANGO"?T.amber:curveLbl==="BACKWARDATION"?T.green:T.textMid;
  const wf=[
    {n:"Acq.(SPA)",v:-(pEu.supply/1e6),     fill:T.redDim},
    {n:"Charter",  v:-(pEu.charter/1e6),     fill:T.amber},
    {n:"Fuel",     v:-(pEu.fuel/1e6),        fill:T.amberDim},
    {n:"Capital",  v:-(pEu.capitalCost/1e6), fill:T.amberDim},
    {n:"Regas",    v:-(pEu.regas/1e6),       fill:"#9B6020"},
    {n:"Ports",    v:-(pEu.ports/1e6),       fill:T.textDim},
    {n:"Revenue",  v: pEu.revenue/1e6,       fill:T.cyan},
    {n:"MARGIN",   v: pEu.profit/1e6,        fill:pEu.profit>0?T.green:T.red},
  ];
  const stressActive=stressMode&&SS[stressMode];
  const regimeInfo=REGIME[regime];
  const dqHH=realPrices.hhDq??"SIM",dqTTF=realPrices.ttfDq??"SIM",dqJKM="PROXY",dqFX=realPrices.fxDq??"SIM";
  const kellyEU=mc?(mc.eu.mean/Math.max(mc.eu.std**2,1))*1e6:null;
  const kellySugg=kellyEU!==null?Math.max(0,Math.min(100,Math.round(kellyEU*0.5))):null;

  /* ═══ RENDER ═══════════════════════════════════════════════════════ */
  return(
    <div style={{width:"100%",minHeight:"100vh",background:T.bg0,color:T.text,fontFamily:FM,overflowX:"hidden"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Barlow+Condensed:wght@400;600;700;800&display=swap');
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        html,body,#root{width:100%;overflow-x:hidden}
        ::-webkit-scrollbar{width:4px;height:4px}
        ::-webkit-scrollbar-track{background:${T.bg0}}
        ::-webkit-scrollbar-thumb{background:${T.line2};border-radius:2px}
        .ctrl{cursor:pointer;border:1px solid ${T.line2};border-radius:2px;padding:4px 10px;font-family:${FC};font-size:11px;font-weight:700;letter-spacing:0.1em;background:transparent;transition:all .12s;text-transform:uppercase;color:${T.textMid}}
        .ctrl:hover{background:${T.bg3};border-color:${T.cyan};color:${T.cyan}}
        .ctrl.active{background:${T.bg2};border-color:${T.cyan};color:${T.cyan}}
        .ldot{animation:lp 1.6s ease-in-out infinite}
        @keyframes lp{0%,100%{opacity:1;box-shadow:0 0 6px ${T.green}}50%{opacity:.2;box-shadow:none}}
        .crs-pulse{animation:crp 0.8s ease-in-out infinite}
        @keyframes crp{0%,100%{opacity:1;box-shadow:0 0 8px ${T.red}}50%{opacity:0.5;box-shadow:none}}
        input[type=range]{-webkit-appearance:none;height:3px;border-radius:2px;background:${T.line2};outline:none;cursor:pointer;width:100%}
        input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:11px;height:11px;border-radius:50%;background:${T.cyan};cursor:pointer;border:2px solid ${T.bg0}}
      `}</style>
      <Sidebar params={params} onUpdate={updateParam} isOpen={sidebarOpen} onToggle={()=>setSidebarOpen(o=>!o)} realPrices={realPrices}/>
      <div style={{width:"100%",padding:"10px 13px"}}>

        {/* ── TOP BAR ─────────────────────────────────────────────── */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8,paddingBottom:8,borderBottom:`1px solid ${T.line2}`,flexWrap:"wrap",gap:5}}>
          <div>
            <div style={{fontFamily:FC,fontWeight:800,fontSize:20,color:T.cyan,letterSpacing:"0.03em",lineHeight:1,display:"flex",alignItems:"baseline",gap:9,flexWrap:"wrap"}}>
              LNG FRONTIER OPTIMIZER
              <span style={{fontFamily:FM,fontSize:8,color:T.green,background:`${T.green}18`,border:`1px solid ${T.green}44`,padding:"2px 7px",borderRadius:2,letterSpacing:"0.12em"}}>FULL FUNDAMENTALS v7.1</span>
              <span className={regime==="crisis"?"crs-pulse":""} style={{fontFamily:FM,fontSize:8,color:regimeInfo.color,background:`${regimeInfo.color}18`,border:`1px solid ${regimeInfo.color}`,padding:"2px 7px",borderRadius:2}}>{regime==="crisis"?"⚡":"●"} {regimeInfo.shortLabel}</span>
              {stressActive&&<span style={{fontFamily:FM,fontSize:8,color:stressActive.color,background:`${stressActive.color}20`,border:`1px solid ${stressActive.color}`,padding:"2px 8px",borderRadius:2,animation:"lp 1.2s infinite"}}>{stressActive.icon} {stressActive.label}</span>}
            </div>
