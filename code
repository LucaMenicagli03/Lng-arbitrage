/* ════════════════════════════════════════════════════════════════════════
   MATRIX COLOR ENGINE v6.1  — direct zone lookup, zero float math
   ─────────────────────────────────────────────────────────────────────
   No rgb() interpolation, no hexToRgb helper, no position:absolute in
   table cells. Each margin zone maps directly to a hardcoded bg+fg pair.
   This eliminates all NaN / rendering crash vectors from the old version.
════════════════════════════════════════════════════════════════════════ */
function matCell(margin) {
  if (margin >=  2.0) return { bg:"#002B10", fg:"#00FF88", bepZone:false };
  if (margin >=  1.0) return { bg:"#004D1E", fg:"#00E070", bepZone:false };
  if (margin >=  0.15)return { bg:"#006630", fg:"#80FFB8", bepZone:false };
  if (margin >=  0.0) return { bg:"#1A3A20", fg:"#60D080", bepZone:true  };
  if (margin >= -0.15)return { bg:"#3A1A1A", fg:"#FF8080", bepZone:true  };
  if (margin >= -1.0) return { bg:"#7A1020", fg:"#FFB0B0", bepZone:false };
  if (margin >= -2.0) return { bg:"#A00822", fg:"#FFC0C0", bepZone:false };
  /* margin < -2.0 */ return { bg:"#6B0018", fg:"#FFD0D0", bepZone:false };
}

/* ════════════════════════════════════════════════════════════════════════
