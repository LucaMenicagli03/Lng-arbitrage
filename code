          <Param label="REGAS FEE (AP)" value={params.regasFeeAP} min={0.10} max={0.80} step={0.01}
            onChange={v=>onUpdate("regasFeeAP",v)} unit="$/MMBtu" prec={2} color={T.amber} note="Tokyo Gas / Sodegaura"/>
        </Sec>

        {/* FIX#7 — B/L Price Lock */}
        <Sec title="Cargo Position — B/L Price Lock" accent={T.purple}
          sub={"Lock sell price at B/L date.\nWhen active: revenue uses fixed price,\nnot live market."}>
