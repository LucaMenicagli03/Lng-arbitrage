/* ════════════════════════════════════════════════════════════════════════
   ROUTE RESOLVER
════════════════════════════════════════════════════════════════════════ */
function resolveRoute(id, p) {
  if (id === "EU") return {
    nm: NM.EU, thermal: THERMAL.EU, canal: p.canalEU,
    warRisk: 0, regasFee: p.regasFeeEU,
  };
  const key = p.useCape ? "AP_CAPE" : "AP_SUEZ";
  return {
    nm: NM[key], thermal: THERMAL[key],
    canal:   p.useCape ? 0 : p.canalAP,
    warRisk: p.useCape ? 0 : (p.suezWarActive ? p.warRiskSuez : 0),
    regasFee: p.regasFeeAP,
  };
}

function travelDays(nm, spd) { return nm / (spd * 24); }

/* ════════════════════════════════════════════════════════════════════════
   CORE P&L ENGINE — v6.1
   ─────────────────────────────────────────────────────────────────────
   FIX v6.1a — Dual-fuel opportunity cost (BOG) corrected:
     Previous: bogOppCost = bog × max(0, HH×slope − HFO_threshold)
     Problem:  HH×slope is the ACQUISITION cost, not the sell value.
               At HH=$3.52, HH×slope=$3.92, always < HFO_threshold=$11.85
               → OC was perpetually zero. Economically wrong.
     Correct:  The BOG burned as fuel displaces HFO at $11.85/MMBtu equiv.
               If the destination sell price > $11.85/MMBtu, each MMBtu
               burned is worth (sellPrice − HFO_equiv) that you forgo.
               bogOppCost = bog × max(0, sellPrice − HFO_per_mmbtu)
   FIX v6.1b — Capital cost (cost of capital):
     The cargo purchase immobilizes capital for td days.
     capitalCost = supply × (sofr/100) × (td / 365)
     At SOFR=5.3%, supply=$120M, td=19d → ~$330k cargo-level cost
     Previously invisible → break-even price was systematically too low.
════════════════════════════════════════════════════════════════════════ */
function calcProfit(hh, destUsd, p, routeId, extraDelayDays = 0) {
  const route   = resolveRoute(routeId, p);
  const seaMult = SEA_STATE[p.seaState]?.mult ?? 1.0;

  const heelMmbtu  = p.heelM3 * LNG_DENSITY * LNG_MMBTU_TON;
  const loadMmbtu  = Math.max(0, p.capacityM3 * LNG_DENSITY * LNG_MMBTU_TON - heelMmbtu);

  const borNom  = p.borRate / 100;
  const borEff  = borNom * route.thermal * seaMult;
  const td      = travelDays(route.nm, p.speedKnots) + extraDelayDays;
  const deliv   = loadMmbtu * Math.pow(1 - borEff, td);
  const bog     = loadMmbtu - deliv;

  // B/L lock determination (needed before OC calc)
  const blLocked = p.blPriceLocked && (routeId === "EU" ? p.blPriceEU : p.blPriceAP) > 0;
  const sellPrice = blLocked
    ? (routeId === "EU" ? p.blPriceEU : p.blPriceAP)
    : destUsd;

  const bogHfoEquiv = bog / HFO_E_MMBTU;
  const netHfo      = Math.max(0, FUEL_DAY_MT * td - bogHfoEquiv);
  // FIX v6.1a: OC = (sell_price − HFO_equiv) per MMBtu of BOG burned as fuel
  // When sell_price > $11.85/MMBtu you are giving up margin by burning BOG
  const bogOppCost  = bog * Math.max(0, sellPrice - HFO_PER_MMBTU);
  const fuel        = netHfo * HFO_PRICE_USD + bogOppCost;
  const hfoCost     = netHfo * HFO_PRICE_USD;

  const acqPerMmbtu = hh * p.spaSlope + p.sTolling + p.sLiquefaction;
  const supply      = loadMmbtu * acqPerMmbtu;

  const ballastDays = td * p.ballastFactor;
  const charter     = p.charterRate * (td + ballastDays);

  const regas  = deliv * route.regasFee;
  const ports  = p.portOrigin + p.portDest + route.canal + route.warRisk;

  // FIX v6.1b: Capital cost — cost of capital tied up during voyage
  const sofr        = (p.sofr ?? 5.30) / 100;
  const capitalCost = supply * sofr * (td / 365);

  const revenue = deliv * sellPrice;
  const total   = supply + charter + fuel + regas + ports + capitalCost;

  const breakEvenDest  = total / Math.max(deliv, 1);
  const marginPerMmbtu = sellPrice - breakEvenDest;
  const marginTotal    = marginPerMmbtu * deliv;

  return {
    profit: revenue - total,
    revenue, supply, charter, fuel, hfoCost, regas, ports, total,
    capitalCost, bogOppCost,
    deliv, td, bog, borEff,
    heelMmbtu, loadMmbtu, ballastDays,
    acqPerMmbtu, breakEvenDest, marginPerMmbtu, marginTotal,
    sellPrice, blLocked,
    hhInput: hh,
  };
}

/* ════════════════════════════════════════════════════════════════════════
   ROUTE BREAK-EVEN: Suez vs Cape
════════════════════════════════════════════════════════════════════════ */
function calcRouteBreakeven(hh, jkm, p) {
  const pSuez = calcProfit(hh, jkm, { ...p, useCape:false }, "AP");
  const pCape = calcProfit(hh, jkm, { ...p, useCape:true  }, "AP");
  const tdS   = travelDays(NM.AP_SUEZ, p.speedKnots);
  const tdC   = travelDays(NM.AP_CAPE, p.speedKnots);
  return {
    suezProfit: pSuez.profit, capeProfit: pCape.profit,
    optimal: pSuez.profit >= pCape.profit ? "SUEZ" : "CAPE",
    extraDays: tdC - tdS,
    suezFees: p.canalAP + (p.suezWarActive ? p.warRiskSuez : 0),
    capeExtraCost: (tdC - tdS) * p.charterRate * (1 + p.ballastFactor),
  };
}

/* ════════════════════════════════════════════════════════════════════════
   CARGO DIVERSION ENGINE
════════════════════════════════════════════════════════════════════════ */
function calcCargoDiversion(hh, ttfUsd, jkm, p, progressFrac = 0.5) {
  const seaMult   = SEA_STATE[p.seaState]?.mult ?? 1.0;
  const heelMmbtu = p.heelM3 * LNG_DENSITY * LNG_MMBTU_TON;
  const loadMmbtu = Math.max(0, p.capacityM3 * LNG_DENSITY * LNG_MMBTU_TON - heelMmbtu);
  const borNom    = p.borRate / 100;
  const spd       = p.speedKnots;

  const nmDone    = NM.EU * progressFrac;
  const borEU     = borNom * THERMAL.EU * seaMult;
  const tdDone    = travelDays(nmDone, spd);
  const cargoNow  = loadMmbtu * Math.pow(1 - borEU, tdDone);

  const nmEuLeft  = NM.EU - nmDone;
  const tdEuLeft  = travelDays(nmEuLeft, spd);
  const delivEU   = cargoNow * Math.pow(1 - borEU, tdEuLeft);
  const charterEU = p.charterRate * tdEuLeft * (1 + p.ballastFactor);
  const revenueEU = delivEU * ttfUsd - delivEU * p.regasFeeEU - p.portDest - charterEU;

  // FIX v6.0: Use actual remaining nautical miles for AP diversion,
  // not the heuristic nmEuLeft * 1.05 which was arbitrary.
  const nmAP      = p.useCape ? NM.AP_CAPE : NM.AP_SUEZ;
  // Remaining distance to AP from current position (U-turn + AP route)
  const nmDivert  = nmAP - nmDone + nmDone * 0.15; // ~15% backtrack penalty
  const tdDiv     = travelDays(Math.max(nmDivert, nmEuLeft), spd);
  const borAP     = borNom * (p.useCape ? THERMAL.AP_CAPE : THERMAL.AP_SUEZ) * seaMult;
  const delivAP   = cargoNow * Math.pow(1 - borAP, tdDiv);
  const charterAP = p.charterRate * tdDiv * (1 + p.ballastFactor);
  const revenueAP = delivAP * jkm - delivAP * p.regasFeeAP
    - p.portDest - charterAP - p.diversionPenalty
    - (p.suezWarActive && !p.useCape ? p.warRiskSuez + p.canalAP : 0);

  const delta        = revenueAP - revenueEU;
  const jkmThreshold = ttfUsd
    + p.diversionPenalty / Math.max(delivAP, 1)
    + (p.regasFeeAP - p.regasFeeEU)
    + (tdDiv - tdEuLeft) * p.charterRate * (1 + p.ballastFactor) / Math.max(delivAP, 1);

  return { shouldDivert: delta > 0, delta, jkmThreshold, revenueEU, revenueAP, delivEU, delivAP };
}

/* ════════════════════════════════════════════════════════════════════════
   MATHEMATICAL ENGINE v6.0
   ─────────────────────────────────────────────────────────────────────
   NEW: Student-t distribution (ν=4) for jump magnitudes.
        Addresses README: "VaR likely understated 40-60% due to log-normal
        jump size assumption. Empirical gas price distributions have
        asymmetric fat tails."
        Student-t(ν=4) produces tails ~35% wider than Gaussian.
════════════════════════════════════════════════════════════════════════ */
const OU_KAPPA = 0.15;
const CORR = [[1,0.65,0.55],[0.65,1,0.70],[0.55,0.70,1]];
// MU: long-run means for OU. HH and TTF are calibrated constants.
// JKM long-run mean is now params-driven (params.muJkm) to fix the
// hardcoded HH×3.8+1.5 that became stale in 2024-25 oversupply regime.
const MU_HH  = 3.52;
const MU_TTF = 29.50;
// Fallback used before params are available (seed/init calls)
const MU_JKM_DEFAULT = 13.50;
// Helper: get full MU object respecting params.muJkm if present
function getMU(params) {
  return { hh: MU_HH, ttf: MU_TTF, jkm: params?.muJkm ?? MU_JKM_DEFAULT };
}
// Keep backward compat constant for functions that don't take params
const MU = { hh: MU_HH, ttf: MU_TTF, jkm: MU_JKM_DEFAULT };

function choleskyL(C) {
  const n=C.length, L=Array.from({length:n},()=>Array(n).fill(0));
  for(let i=0;i<n;i++) for(let j=0;j<=i;j++){
    let s=C[i][j]; for(let k=0;k<j;k++) s-=L[i][k]*L[j][k];
    L[i][j]=j===i?Math.sqrt(Math.max(s,1e-14)):s/L[j][j];
  }
  return L;
}
const LC = choleskyL(CORR);

function randn(){
  let u=0,v=0;
  while(!u)u=Math.random();while(!v)v=Math.random();
  return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);
}

/**
 * Student-t random variate — Box-Muller + chi-squared construction.
 * ν=4: kurtosis = 6 (vs 0 for Gaussian), fat tails for commodity jumps.
 * Partially corrects README-acknowledged VaR understatement.
 */
function studentT(nu = 4) {
  const z = randn();
  let chi2 = 0;
  for (let i = 0; i < nu; i++) chi2 += randn() ** 2;
  return z / Math.sqrt(chi2 / nu);
}

function poissonSample(lam){
  if(lam<=0)return 0;
  const L=Math.exp(-Math.min(lam,20));let k=0,p=1;
  do{k++;p*=Math.random();}while(p>L);return k-1;
}

/**
 * CVaR (Conditional VaR / Expected Shortfall) at confidence level alpha.
 * Coherent risk measure, strictly superior to VaR for fat-tail distributions.
 * CVaR_alpha = E[X | X < VaR_alpha]
 * @param {number[]} sortedAsc - sorted ascending array
 * @param {number} alpha - tail probability (0.05 for 95% CVaR)
 */
function calcCVaR(sortedAsc, alpha) {
  const cutIdx = Math.floor(sortedAsc.length * alpha);
  if (cutIdx === 0) return sortedAsc[0];
  const tail = sortedAsc.slice(0, cutIdx);
  return tail.reduce((a, v) => a + v, 0) / tail.length;
}

const VOL_PRESETS = {
  low:    {hh:0.20,ttf:0.25,jkm:0.18},
  normal: {hh:0.45,ttf:0.55,jkm:0.40},
  high:   {hh:0.80,ttf:0.95,jkm:0.70},
};

/**
 * OU step with regime-aware kappa and vol multipliers.
 * @param {object} prices - current price state
 * @param {object} vols - volatility preset
 * @param {number} dt - time step in years
 * @param {string} regimeKey - "normal" | "crisis"
 */
function ouStep(prices, vols, dt, regimeKey = "normal", muJkm = MU_JKM_DEFAULT){
  const reg  = REGIME[regimeKey] ?? REGIME.normal;
  const kap  = OU_KAPPA * reg.kappaMult;
  const vmul = reg.volMult;
  const z=[randn(),randn(),randn()];
  const zc=[
    LC[0][0]*z[0],
    LC[1][0]*z[0]+LC[1][1]*z[1],
    LC[2][0]*z[0]+LC[2][1]*z[1]+LC[2][2]*z[2],
  ];
  return {
    hh:  Math.max(prices.hh  +(MU_HH  -prices.hh )*kap*dt+vols.hh *vmul*prices.hh *Math.sqrt(dt)*zc[0],0.30),
    ttf: Math.max(prices.ttf +(MU_TTF -prices.ttf)*kap*dt+vols.ttf*vmul*prices.ttf*Math.sqrt(dt)*zc[1],5.00),
    jkm: Math.max(prices.jkm +(muJkm  -prices.jkm)*kap*dt+vols.jkm*vmul*prices.jkm*Math.sqrt(dt)*zc[2],6.00),
  };
}

function ttfToUsd(e,fx){return (e*fx)/3.41214;}

/* ════════════════════════════════════════════════════════════════════════
   MONTE CARLO v6.0 — Student-t jumps + charter correlation + CVaR
   ─────────────────────────────────────────────────────────────────────
   NEW v6.0 improvements vs v5.0:
   (a) Jump sizes: Student-t(ν=4) instead of Gaussian → fatter tails
   (b) Charter rate crisis correlation: ρ≈+0.65 with TTF jump events
       (Baltic LNG Index historically spikes during supply disruptions)
   (c) CVaR / Expected Shortfall at 95% and 99% confidence levels
   (d) Regime-aware volatility: crisis regime doubles vol + reduces kappa
════════════════════════════════════════════════════════════════════════ */
function runMCAdvanced(hh, ttfUsd, jkm, params, vols, stressMode=null, regimeKey="normal", N=700){
  const seaMult    = SEA_STATE[params.seaState]?.mult ?? 1.0;
  const heelMmbtu  = params.heelM3 * LNG_DENSITY * LNG_MMBTU_TON;
  const loadMmbtu  = Math.max(0, params.capacityM3*LNG_DENSITY*LNG_MMBTU_TON - heelMmbtu);
  const borNom     = params.borRate/100;
  const {charterRate,ballastFactor,spaSlope,sTolling,sLiquefaction,
         regasFeeEU,regasFeeAP,portOrigin,portDest,lambdaJump=0.5,sigmaJump=0.30} = params;
  const sofr       = (params.sofr ?? 5.30) / 100;

  const stressVolMult = stressMode ? (SS[stressMode]?.volMult??1) : 1;
  const regVolMult    = REGIME[regimeKey]?.volMult ?? 1.0;
  const totalVolMult  = stressVolMult * regVolMult;
  const sv = {hh:vols.hh*totalVolMult, ttf:vols.ttf*totalVolMult, jkm:vols.jkm*totalVolMult};

  const rEU    = resolveRoute("EU",params);
  const rAP    = resolveRoute("AP",params);
  const tdEU0  = travelDays(rEU.nm,params.speedKnots);
  const tdAP0  = travelDays(rAP.nm,params.speedKnots);
  const dt     = tdEU0/365;
  const apTKey = params.useCape ? "AP_CAPE" : "AP_SUEZ";
  const regJumpMult = REGIME[regimeKey]?.jumpMult ?? 1.0;

  const pEU=[], pAP=[];

  for(let i=0;i<N;i++){
    const z=[randn(),randn(),randn()];
    const zc=[
      LC[0][0]*z[0],
      LC[1][0]*z[0]+LC[1][1]*z[1],
      LC[2][0]*z[0]+LC[2][1]*z[1]+LC[2][2]*z[2],
    ];

    const effLambda = lambdaJump * regJumpMult;
    const nTTF = poissonSample(effLambda*dt);
    const nJKM = poissonSample(effLambda*(1+(nTTF>0?0.60:0))*dt);
    const nHH  = poissonSample(effLambda*0.25*dt);

    const jF = (n,s) => {
      if(n===0) return {up:1, dn:1};
      let ls=0;
      for(let j=0;j<n;j++) ls += s * studentT(4);
      return {up:Math.exp(ls), dn:Math.exp(-ls*0.40)};
    };
    const jT=jF(nTTF,sigmaJump), jJ=jF(nJKM,sigmaJump), jH=jF(nHH,sigmaJump*0.5);

    const hhS  = Math.max(hh   *(1+sv.hh *Math.sqrt(dt)*zc[0])*jH.dn, 0.30);
    const ttfS = Math.max(ttfUsd*(1+sv.ttf*Math.sqrt(dt)*zc[1])*jT.up, 3.00);
    const jkmS = Math.max(jkm  *(1+sv.jkm*Math.sqrt(dt)*zc[2])*jJ.up, 6.00);

    const charterCrisisShock = nTTF > 0 ? (1 + 0.65 * Math.abs(studentT(6))) : 1.0;
    const cr = charterRate * charterCrisisShock * (1 + randn()*0.04);

    const delay  = Math.max(0, Math.exp(randn()*0.4)-1);
    const suezC  = !params.useCape ? Math.max(0, Math.exp(randn()*0.8)*0.5) : 0;

    const acqC = hhS*spaSlope + sTolling + sLiquefaction;
    const supply = loadMmbtu * acqC;

    // EU route
    const tdEUs  = tdEU0+delay;
    const borEUs = borNom*THERMAL.EU*seaMult;
    const dEU    = loadMmbtu*Math.pow(1-borEUs, tdEUs);
    const bogEU  = loadMmbtu-dEU;
    const nHEU   = Math.max(0, FUEL_DAY_MT*tdEUs - bogEU/HFO_E_MMBTU);
    const blEU   = (params.blPriceLocked&&params.blPriceEU>0)?params.blPriceEU:ttfS;
    // FIX v6.1a: BOG OC uses sell price, not HH*slope
    const occEU  = bogEU*Math.max(0, blEU - HFO_PER_MMBTU);
    const chEU   = cr*(tdEUs+tdEUs*ballastFactor);
    // FIX v6.1b: capital cost
    const capCostEU = supply * sofr * (tdEUs / 365);
    pEU.push(dEU*blEU - supply - chEU - nHEU*HFO_PRICE_USD - occEU
             - dEU*regasFeeEU - rEU.canal - rEU.warRisk - portOrigin - portDest - capCostEU);

    // AP route
    const tdAPs  = tdAP0+delay*1.5+suezC;
    const borAPs = borNom*THERMAL[apTKey]*seaMult;
    const dAP    = loadMmbtu*Math.pow(1-borAPs, tdAPs);
    const bogAP  = loadMmbtu-dAP;
    const nHAP   = Math.max(0, FUEL_DAY_MT*tdAPs - bogAP/HFO_E_MMBTU);
    const blAP   = (params.blPriceLocked&&params.blPriceAP>0)?params.blPriceAP:jkmS;
    // FIX v6.1a: BOG OC uses sell price for AP too
    const occAP  = bogAP*Math.max(0, blAP - HFO_PER_MMBTU);
    const chAP   = cr*(tdAPs+tdAPs*ballastFactor);
    // FIX v6.1b: capital cost for AP (longer voyage = more capital tied up)
    const capCostAP = supply * sofr * (tdAPs / 365);
    pAP.push(dAP*blAP - supply - chAP - nHAP*HFO_PRICE_USD - occAP
             - dAP*regasFeeAP - rAP.canal - rAP.warRisk - portOrigin - portDest - capCostAP);
  }

  const stats=(arr)=>{
    const s=[...arr].sort((a,b)=>a-b);
    const mean=s.reduce((a,v)=>a+v,0)/N;
    const std=Math.sqrt(s.reduce((a,v)=>a+(v-mean)**2,0)/N);
    const v95=s[Math.floor(N*0.05)], v99=s[Math.floor(N*0.01)];
    // v6.0: CVaR (Expected Shortfall) — coherent risk measure
    const cvar95 = calcCVaR(s, 0.05);
    const cvar99 = calcCVaR(s, 0.01);
    const mn=s[0],mx=s[N-1],step=(mx-mn)/24||1;
    const bins=Array.from({length:24},(_,i)=>{
      const lo=mn+step*i,mid=lo+step/2;
      return{x:(mid/1e6).toFixed(2),n:s.filter(v=>v>=lo&&v<lo+step).length,
             pos:mid>0,vz:mid<v99?2:mid<v95?1:0};
    });
    return{mean,std,var95:v95,var99:v99,cvar95,cvar99,bins,
           probP:s.filter(v=>v>0).length/N*100,
           sharpe:mean/Math.max(std,1),p95:s[Math.floor(N*0.95)]};
  };

  const eu=stats(pEU), ap=stats(pAP);
  const volRatio=ap.std/Math.max(eu.std,1);
  return{eu,ap,volRatio,riskWarn:volRatio>1.8,...eu};
}

/* ════════════════════════════════════════════════════════════════════════
   SENSITIVITY — Tornado Chart ±1% per driver (EU route)
════════════════════════════════════════════════════════════════════════ */
function calcSpider(p, hh, ttfUsd, jkm){
  const d=0.01;
  const base=calcProfit(hh,ttfUsd,p,"EU").marginTotal;
  if(Math.abs(base)<1)return[];
  const eu=(mutP,h=hh,t=ttfUsd)=>calcProfit(h,t,mutP,"EU").marginTotal;
  const ap=(mutP,h=hh,j=jkm)=>calcProfit(h,j,mutP,"AP").marginTotal;
  const pct=v=>+((v-base)/Math.abs(base)*100).toFixed(2);
  return [
    {label:"HH Gas Price",   up:pct(eu(p,hh*(1+d))),  dn:pct(eu(p,hh*(1-d)))},
    {label:"TTF Dest Price", up:pct(eu(p,hh,ttfUsd*(1+d))), dn:pct(eu(p,hh,ttfUsd*(1-d)))},
    {label:"Charter Rate",   up:pct(eu({...p,charterRate:p.charterRate*(1+d)})), dn:pct(eu({...p,charterRate:p.charterRate*(1-d)}))},
    {label:"SPA Slope",      up:pct(eu({...p,spaSlope:p.spaSlope*(1+d)})), dn:pct(eu({...p,spaSlope:p.spaSlope*(1-d)}))},
    {label:"Boil-Off Rate",  up:pct(eu({...p,borRate:p.borRate*(1+d)})), dn:pct(eu({...p,borRate:p.borRate*(1-d)}))},
    {label:"Ballast Factor", up:pct(eu({...p,ballastFactor:p.ballastFactor*(1+d)})), dn:pct(eu({...p,ballastFactor:p.ballastFactor*(1-d)}))},
    {label:"JKM (AP Alt.)",  up:pct(ap(p,hh,jkm*(1+d))), dn:pct(ap(p,hh,jkm*(1-d)))},
  ].sort((a,b)=>Math.abs(b.up)-Math.abs(a.up))
   .map(r=>({subject:r.label,upside:r.up,downside:r.dn}));
}

/* ════════════════════════════════════════════════════════════════════════
   BREAK-EVEN SENSITIVITY MATRIX v6.0 — NEW
   2D grid: HH price (rows) × Destination price (cols) → Margin $/MMBtu
   The most operationally useful pre-trade tool for a trader:
   "Given my SPA cost at this HH, what destination price do I need?"
════════════════════════════════════════════════════════════════════════ */
/* ════════════════════════════════════════════════════════════════════════
   BREAK-EVEN MATRIX ENGINE v6.1
   Grid: 7 HH rows × 7 Destination cols
   HH range ±20%, Dest range ±25% — broader than v6.0 per trader feedback
════════════════════════════════════════════════════════════════════════ */
function calcBreakEvenMatrix(params, hh, destUsd, routeId) {
  const STEPS    = 7;
  const hhDelta  = hh * 0.20;
  const dstDelta = destUsd * 0.25;
  const hhSteps   = Array.from({length: STEPS}, (_, i) =>
    Math.max(0.30, hh - hhDelta + (2 * hhDelta / (STEPS - 1)) * i));
  const destSteps = Array.from({length: STEPS}, (_, i) =>
    Math.max(1.00, destUsd - dstDelta + (2 * dstDelta / (STEPS - 1)) * i));
  const matrix = hhSteps.map(h =>
    destSteps.map(d => {
      const res = calcProfit(h, d, params, routeId);
      return { margin: res.marginPerMmbtu, bep: res.breakEvenDest, acq: res.acqPerMmbtu };
    })
  );
  return { hhSteps, destSteps, matrix };
}

