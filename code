  const Param=({label,value,min,max,step,onChange,unit,prec=0,color=T.cyan,note})=>(<div style={{marginBottom:9}}>
    <div style={{display:"flex",justifyContent:"space-between",marginBottom:2,alignItems:"baseline"}}>
      <span style={{fontFamily:FC,fontSize:9,color:T.textMid,letterSpacing:"0.1em"}}>{label}</span>
