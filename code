/** FRED API — singola serie, ultimo valore non nullo */
async function fetchFRED(sid) {
  try {
    const r = await fetch(
      `https://api.stlouisfed.org/fred/series/observations?series_id=${sid}`+
      `&api_key=${API.FRED}&sort_order=desc&limit=5&file_type=json`,
      {signal:AbortSignal.timeout(9000)}
    );
    if(!r.ok) throw new Error(`FRED ${r.status}`);
    const d = await r.json();
    const obs = (d.observations||[]).find(o=>o.value&&o.value!=".");
    if(!obs) return null;
    return {value:parseFloat(obs.value), date:obs.date, dq:"LIVE"};
  } catch(e) { console.warn(`FRED ${sid}:`,e.message); return null; }
}

/** EIA API v2 — NG Futures RNGC1/2/3/4 (Henry Hub NYMEX M1-M4)
 *  Ritorna array [{month:"M1",price:4.12,series:"RNGC1"}, ...]
 *  NUOVO v7.1: forward curve M1-M4 reale, non OU simulata
 */
async function fetchEIAFutures() {
  try {
    const series = ["RNGC1","RNGC2","RNGC3","RNGC4"];
    const facets = series.map(s=>`facets[series][]=${s}`).join("&");
    const url = `https://api.eia.gov/v2/natural-gas/pri/fut/data/`+
      `?api_key=${API.EIA}&frequency=daily&data[0]=value&${facets}`+
      `&sort[0][column]=period&sort[0][direction]=desc&length=20`;
    const r = await fetch(url,{signal:AbortSignal.timeout(10000)});
    if(!r.ok) throw new Error(`EIA futures ${r.status}`);
    const d = await r.json();
    const rows = d?.response?.data ?? [];
    // Per ogni serie prendi il valore più recente
    const result = {};
    for(const s of series) {
      const row = rows.find(r=>r.series===s && r.value && r.value!=="null");
      if(row) result[s] = {price:parseFloat(row.value), period:row.period};
    }
    return Object.keys(result).length >= 2 ? result : null;
  } catch(e) { console.warn("EIA futures:",e.message); return null; }
}

/** EIA API v2 — US LNG Exports weekly (Bcf/d o MMcf/d)
 *  NUOVO v7.1: supply signal → quando alto, più LNG sul mercato → JKM bearish
 */
async function fetchEIALngExports() {
  try {
    const url = `https://api.eia.gov/v2/natural-gas/move/lngexp/data/`+
      `?api_key=${API.EIA}&frequency=weekly&data[0]=value`+
      `&sort[0][column]=period&sort[0][direction]=desc&length=8`;
    const r = await fetch(url,{signal:AbortSignal.timeout(10000)});
    if(!r.ok) throw new Error(`EIA LNG exp ${r.status}`);
    const d = await r.json();
    const rows = d?.response?.data ?? [];
    if(!rows.length) return null;
    const cur  = parseFloat(rows[0].value);
    const prev = rows[1] ? parseFloat(rows[1].value) : cur;
    const avg4 = rows.slice(0,4).reduce((a,v)=>a+parseFloat(v.value),0)/Math.min(4,rows.length);
    return {
      value:cur, prev, change:cur-prev,
      avg4wk:avg4,
      pctVsAvg:((cur-avg4)/avg4*100),
      period:rows[0].period,
      // High export → more LNG globally → slight JKM bearish signal
      jkmBearish: cur > avg4*1.05,
      dq:"LIVE",
    };
  } catch(e) { console.warn("EIA LNG exports:",e.message); return null; }
}

