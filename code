/* ─── Ticker Cell ─────────────────────────────────────────────────────── */
function Ticker({label,value,delta,unit,color}) {
  const ref=useRef();
  useEffect(()=>{
    if(!ref.current) return;
    ref.current.style.color=T.flash;
    const t=setTimeout(()=>{ if(ref.current) ref.current.style.color=color; },120);
    return ()=>clearTimeout(t);
  },[value]);
  return (
    <Card accent={color} style={{padding:"10px 12px"}}>
      <div style={{fontFamily:FONT_COND,fontSize:9,fontWeight:700,color:T.textMid,
        letterSpacing:"0.14em",textTransform:"uppercase",marginBottom:4}}>{label}</div>
      <div ref={ref} style={{fontFamily:FONT_MONO,fontSize:17,fontWeight:700,
        color,lineHeight:1,transition:"color .12s"}}>
        {value}
        <span style={{fontSize:9,color:T.textDim,marginLeft:4}}>{unit}</span>
      </div>
      <div style={{fontFamily:FONT_MONO,fontSize:9,color:pColor(delta),marginTop:3}}>
        {arrow(delta)} {Math.abs(delta).toFixed(3)}
      </div>
    </Card>
  );
}

