const CORR=[[1,0.65,0.55],[0.65,1,0.70],[0.55,0.70,1]];
function choleskyL(C){const n=C.length,L=Array.from({length:n},()=>Array(n).fill(0));for(let i=0;i<n;i++)for(let j=0;j<=i;j++){let s=C[i][j];for(let k=0;k<j;k++)s-=L[i][k]*L[j][k];L[i][j]=j===i?Math.sqrt(Math.max(s,1e-14)):s/L[j][j];}return L;}
const LC=choleskyL(CORR);

/* ── PRNG: Mulberry32 seedable ───────────────────────────────────── */
function mulberry32(seed){let s=seed>>>0;return()=>{s|=0;s=s+0x6D2B79F5|0;let t=Math.imul(s^s>>>15,1|s);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296;};}
function makeRandn(rng){let spare=null;return()=>{if(spare!==null){const v=spare;spare=null;return v;}let u,v,s;do{u=rng()*2-1;v=rng()*2-1;s=u*u+v*v;}while(s>=1||s===0);const m=Math.sqrt(-2*Math.log(s)/s);spare=v*m;return u*m;};}
function randn(){let u=0,v=0;while(!u)u=Math.random();while(!v)v=Math.random();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);}
function poissonSample(lam){if(lam<=0)return 0;const L=Math.exp(-Math.min(lam,20));let k=0,p=1;do{k++;p*=Math.random();}while(p>L);return k-1;}
function studentT(nu=4){const z=randn();let c=0;for(let i=0;i<nu;i++)c+=randn()**2;return z/Math.sqrt(c/nu);}
function calcCVaR(s,a){const ci=Math.floor(s.length*a);if(ci===0)return s[0];return s.slice(0,ci).reduce((a,v)=>a+v,0)/ci;}
function ttfToUsd(e,fx){return(e*fx)/3.41214;}

function ouStep(prices,anchor,vols,dt,regimeKey="normal"){
  const reg=REGIME[regimeKey]??REGIME.normal;
  const kap=CFG.OU_KAPPA*reg.kappaMult, vmul=reg.volMult;
  const z=[randn(),randn(),randn()];
  const zc=[LC[0][0]*z[0],LC[1][0]*z[0]+LC[1][1]*z[1],LC[2][0]*z[0]+LC[2][1]*z[1]+LC[2][2]*z[2]];
  return {
    hh: Math.max(prices.hh +(anchor.hh -prices.hh )*kap*dt+vols.hh *vmul*prices.hh *Math.sqrt(dt)*zc[0],0.30),
    ttf:Math.max(prices.ttf+(anchor.ttf-prices.ttf)*kap*dt+vols.ttf*vmul*prices.ttf*Math.sqrt(dt)*zc[1],3.00),
    jkm:Math.max(prices.jkm+(anchor.jkm-prices.jkm)*kap*dt+vols.jkm*vmul*prices.jkm*Math.sqrt(dt)*zc[2],5.00),
  };
}

function resolveRoute(id,p){
  if(id==="EU")return{nm:NM.EU,thermal:THERMAL.EU,canal:p.canalEU,warRisk:0,regasFee:p.regasFeeEU};
  const key=p.useCape?"AP_CAPE":"AP_SUEZ";
  return{nm:NM[key],thermal:THERMAL[key],canal:p.useCape?0:p.canalAP,warRisk:p.useCape?0:(p.suezWarActive?p.warRiskSuez:0),regasFee:p.regasFeeAP};
}
function travelDays(nm,spd){return nm/(spd*24);}

/* ════════════════════════════════════════════════════════════════════════
   P&L ENGINE v7.1 — invariato da v7.0 (già corretto)
════════════════════════════════════════════════════════════════════════ */
function calcProfit(hh,destUsd,p,routeId,hfoPrice,extraDelayDays=0){
  const hfo=hfoPrice??CFG.HFO_FALLBACK, hfoPMbt=hfo/CFG.HFO_E_MMBTU;
  const route=resolveRoute(routeId,p), seaMult=SEA_STATE[p.seaState]?.mult??1.0;
  const heelMmt=p.heelM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON;
  const loadMmt=Math.max(0,p.capacityM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON-heelMmt);
  const borNom=p.borRate/100, borEff=borNom*route.thermal*seaMult;
  const td=travelDays(route.nm,p.speedKnots)+extraDelayDays;
  const deliv=loadMmt*Math.pow(1-borEff,td), bog=loadMmt-deliv;
  const blLocked=p.blPriceLocked&&(routeId==="EU"?p.blPriceEU:p.blPriceAP)>0;
  const sellPrice=blLocked?(routeId==="EU"?p.blPriceEU:p.blPriceAP):destUsd;
  const bogHfoEq=bog/CFG.HFO_E_MMBTU;
  const netHfo=Math.max(0,fuelPerDay(p.speedKnots,false)*td-bogHfoEq);
  const bogOppCost=bog*Math.max(0,sellPrice-hfoPMbt);
  const fuel=netHfo*hfo+bogOppCost;
  const acqPerMmt=hh*p.spaSlope+p.sTolling+p.sLiquefaction;
  const supply=loadMmt*acqPerMmt;
  const ballastDays=td*p.ballastFactor;
  const charter=p.charterRate*(td+ballastDays);
  const regas=deliv*route.regasFee;
  const ports=p.portOrigin+p.portDest+route.canal+route.warRisk;
  const sofr=(p.sofr??CFG.SOFR_DEFAULT)/100;
  const capitalCost=supply*sofr*(td/365);
  const revenue=deliv*sellPrice;
  const total=supply+charter+fuel+regas+ports+capitalCost;
  const breakEvenDest=total/Math.max(deliv,1);
  const marginPerMmbtu=sellPrice-breakEvenDest;
  const marginTotal=marginPerMmbtu*deliv;
  return{profit:revenue-total,revenue,supply,charter,fuel,hfoCost:netHfo*hfo,regas,ports,total,capitalCost,bogOppCost,deliv,td,bog,borEff,heelMmbtu:heelMmt,loadMmbtu:loadMmt,ballastDays,acqPerMmbtu:acqPerMmt,breakEvenDest,marginPerMmbtu,marginTotal,sellPrice,blLocked,hhInput:hh};
}

function calcRouteBreakeven(hh,jkm,p,hfoPrice){
  const pS=calcProfit(hh,jkm,{...p,useCape:false},"AP",hfoPrice);
  const pC=calcProfit(hh,jkm,{...p,useCape:true },"AP",hfoPrice);
  const tdS=travelDays(NM.AP_SUEZ,p.speedKnots),tdC=travelDays(NM.AP_CAPE,p.speedKnots);
  return{suezProfit:pS.profit,capeProfit:pC.profit,optimal:pS.profit>=pC.profit?"SUEZ":"CAPE",extraDays:tdC-tdS,suezFees:p.canalAP+(p.suezWarActive?p.warRiskSuez:0),capeExtraCost:(tdC-tdS)*p.charterRate*(1+p.ballastFactor)};
}

function calcCargoDiversion(hh,ttfUsd,jkm,p,hfoPrice,progressFrac=0.5){
  const seaMult=SEA_STATE[p.seaState]?.mult??1.0;
  const heelMmt=p.heelM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON;
  const loadMmt=Math.max(0,p.capacityM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON-heelMmt);
  const borNom=p.borRate/100;
  const nmDone=NM.EU*progressFrac,borEU=borNom*THERMAL.EU*seaMult;
  const tdDone=travelDays(nmDone,p.speedKnots),cargoNow=loadMmt*Math.pow(1-borEU,tdDone);
  const nmEuLeft=NM.EU-nmDone,tdEuLeft=travelDays(nmEuLeft,p.speedKnots);
  const delivEU=cargoNow*Math.pow(1-borEU,tdEuLeft);
  const charterEU=p.charterRate*tdEuLeft*(1+p.ballastFactor);
  const revenueEU=delivEU*ttfUsd-delivEU*p.regasFeeEU-p.portDest-charterEU;
  const nmAP=p.useCape?NM.AP_CAPE:NM.AP_SUEZ;
  const nmDivert=nmAP-nmDone+nmDone*0.15;
  const tdDiv=travelDays(Math.max(nmDivert,nmEuLeft),p.speedKnots);
  const borAP=borNom*(p.useCape?THERMAL.AP_CAPE:THERMAL.AP_SUEZ)*seaMult;
  const delivAP=cargoNow*Math.pow(1-borAP,tdDiv);
  const charterAP=p.charterRate*tdDiv*(1+p.ballastFactor);
  const revenueAP=delivAP*jkm-delivAP*p.regasFeeAP-p.portDest-charterAP-p.diversionPenalty-(p.suezWarActive&&!p.useCape?p.warRiskSuez+p.canalAP:0);
  const delta=revenueAP-revenueEU;
  const jkmThreshold=ttfUsd+p.diversionPenalty/Math.max(delivAP,1)+(p.regasFeeAP-p.regasFeeEU)+(tdDiv-tdEuLeft)*p.charterRate*(1+p.ballastFactor)/Math.max(delivAP,1);
  return{shouldDivert:delta>0,delta,jkmThreshold,revenueEU,revenueAP,delivEU,delivAP};
}

/* ── Monte Carlo v7.1 — N=3000, seedable ───────────────────────── */
function runMC(hh,ttfUsd,jkm,params,vols,hfoPrice,stressMode=null,regimeKey="normal",seed=42){
  const N=CFG.MC_N, hfo=hfoPrice??CFG.HFO_FALLBACK, hfoPMbt=hfo/CFG.HFO_E_MMBTU;
  const seaMult=SEA_STATE[params.seaState]?.mult??1.0;
  const heelMmt=params.heelM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON;
  const loadMmt=Math.max(0,params.capacityM3*CFG.LNG_DENSITY*CFG.LNG_MMBTU_TON-heelMmt);
  const borNom=params.borRate/100;
  const{charterRate,ballastFactor,spaSlope,sTolling,sLiquefaction,regasFeeEU,regasFeeAP,portOrigin,portDest,lambdaJump=0.5,sigmaJump=0.30}=params;
  const sofr=(params.sofr??CFG.SOFR_DEFAULT)/100;
  const tvm=(stressMode?(SS[stressMode]?.volMult??1):1)*(REGIME[regimeKey]?.volMult??1.0);
  const sv={hh:vols.hh*tvm,ttf:vols.ttf*tvm,jkm:vols.jkm*tvm};
  const rEU=resolveRoute("EU",params),rAP=resolveRoute("AP",params);
  const tdEU0=travelDays(rEU.nm,params.speedKnots),tdAP0=travelDays(rAP.nm,params.speedKnots);
  const dt=tdEU0/365, apTK=params.useCape?"AP_CAPE":"AP_SUEZ";
  const regJM=REGIME[regimeKey]?.jumpMult??1.0;
  const rng=mulberry32(seed), rnd=makeRandn(rng);
  const jF=(n,s)=>{if(n===0)return{up:1,dn:1};let ls=0;for(let j=0;j<n;j++)ls+=s*studentT(4);return{up:Math.exp(ls),dn:Math.exp(-ls*0.40)};};
  const pEU=[],pAP=[];
  for(let i=0;i<N;i++){
    const z=[rnd(),rnd(),rnd()];
    const zc=[LC[0][0]*z[0],LC[1][0]*z[0]+LC[1][1]*z[1],LC[2][0]*z[0]+LC[2][1]*z[1]+LC[2][2]*z[2]];
    const effL=lambdaJump*regJM;
    const nT=poissonSample(effL*dt),nJ=poissonSample(effL*(1+(nT>0?0.60:0))*dt),nH=poissonSample(effL*0.25*dt);
    const jT=jF(nT,sigmaJump),jJ=jF(nJ,sigmaJump),jH=jF(nH,sigmaJump*0.5);
    const hhS=Math.max(hh*(1+sv.hh*Math.sqrt(dt)*zc[0])*jH.dn,0.30);
    const ttfS=Math.max(ttfUsd*(1+sv.ttf*Math.sqrt(dt)*zc[1])*jT.up,3.00);
    const jkmS=Math.max(jkm*(1+sv.jkm*Math.sqrt(dt)*zc[2])*jJ.up,5.00);
    const crCS=nT>0?(1+0.65*Math.abs(studentT(6))):1.0;
    const cr=charterRate*crCS*(1+rnd()*0.04);
    const delay=Math.max(0,Math.exp(rnd()*0.4)-1);
    const acqC=hhS*spaSlope+sTolling+sLiquefaction, supply=loadMmt*acqC;
    // EU
    const tdEUs=tdEU0+delay;
    const borEUs=borNom*THERMAL.EU*seaMult;
    const dEU=loadMmt*Math.pow(1-borEUs,tdEUs),bogEU=loadMmt-dEU;
    const nHEU=Math.max(0,fuelPerDay(params.speedKnots,false)*tdEUs-bogEU/CFG.HFO_E_MMBTU);
    const blEU=(params.blPriceLocked&&params.blPriceEU>0)?params.blPriceEU:ttfS;
    const occEU=bogEU*Math.max(0,blEU-hfoPMbt);
    const chEU=cr*(tdEUs+tdEUs*ballastFactor);
    const capCostEU=supply*sofr*(tdEUs/365);
    pEU.push(dEU*blEU-supply-chEU-nHEU*hfo-occEU-dEU*regasFeeEU-rEU.canal-rEU.warRisk-portOrigin-portDest-capCostEU);
    // AP
    const suezC=!params.useCape?Math.max(0,Math.exp(rnd()*0.8)*0.5):0;
    const tdAPs=tdAP0+delay*1.5+suezC;
    const borAPs=borNom*THERMAL[apTK]*seaMult;
    const dAP=loadMmt*Math.pow(1-borAPs,tdAPs),bogAP=loadMmt-dAP;
    const nHAP=Math.max(0,fuelPerDay(params.speedKnots,false)*tdAPs-bogAP/CFG.HFO_E_MMBTU);
    const blAP=(params.blPriceLocked&&params.blPriceAP>0)?params.blPriceAP:jkmS;
    const occAP=bogAP*Math.max(0,blAP-hfoPMbt);
    const chAP=cr*(tdAPs+tdAPs*ballastFactor);
    const capCostAP=supply*sofr*(tdAPs/365);
    pAP.push(dAP*blAP-supply-chAP-nHAP*hfo-occAP-dAP*regasFeeAP-rAP.canal-rAP.warRisk-portOrigin-portDest-capCostAP);
  }
  const stats=arr=>{
    const s=[...arr].sort((a,b)=>a-b);
    const mean=s.reduce((a,v)=>a+v,0)/N;
    const std=Math.sqrt(s.reduce((a,v)=>a+(v-mean)**2,0)/N);
    const v95=s[Math.floor(N*0.05)],v99=s[Math.floor(N*0.01)];
    const cvar95=calcCVaR(s,0.05),cvar99=calcCVaR(s,0.01);
    const mn=s[0],mx=s[N-1],step=(mx-mn)/24||1;
    const bins=Array.from({length:24},(_,i)=>{const lo=mn+step*i,mid=lo+step/2;return{x:(mid/1e6).toFixed(2),n:s.filter(v=>v>=lo&&v<lo+step).length,pos:mid>0,vz:mid<v99?2:mid<v95?1:0};});
    return{mean,std,var95:v95,var99:v99,cvar95,cvar99,bins,probP:s.filter(v=>v>0).length/N*100,sharpe:mean/Math.max(std,1),p95:s[Math.floor(N*0.95)]};
  };
  const eu=stats(pEU),ap=stats(pAP);
  return{eu,ap,volRatio:ap.std/Math.max(eu.std,1),riskWarn:ap.std/Math.max(eu.std,1)>1.8,seed,...eu};
}

function calcSpider(p,hh,ttfUsd,jkm,hfoPrice){
  const d=0.01,base=calcProfit(hh,ttfUsd,p,"EU",hfoPrice).marginTotal;
  if(Math.abs(base)<1)return[];
  const eu=(mutP,h=hh,t=ttfUsd)=>calcProfit(h,t,mutP,"EU",hfoPrice).marginTotal;
  const ap=(mutP,h=hh,j=jkm)=>calcProfit(h,j,mutP,"AP",hfoPrice).marginTotal;
  const pct=v=>+((v-base)/Math.abs(base)*100).toFixed(2);
  return[
    {label:"HH Gas Price",  up:pct(eu(p,hh*(1+d))),            dn:pct(eu(p,hh*(1-d)))},
    {label:"TTF Dest Price",up:pct(eu(p,hh,ttfUsd*(1+d))),     dn:pct(eu(p,hh,ttfUsd*(1-d)))},
    {label:"Charter Rate",  up:pct(eu({...p,charterRate:p.charterRate*(1+d)})),dn:pct(eu({...p,charterRate:p.charterRate*(1-d)}))},
    {label:"SPA Slope",     up:pct(eu({...p,spaSlope:p.spaSlope*(1+d)})),      dn:pct(eu({...p,spaSlope:p.spaSlope*(1-d)}))},
    {label:"HFO Price",     up:pct(calcProfit(hh,ttfUsd,p,"EU",hfoPrice*(1+d)).marginTotal),dn:pct(calcProfit(hh,ttfUsd,p,"EU",hfoPrice*(1-d)).marginTotal)},
    {label:"Boil-Off Rate", up:pct(eu({...p,borRate:p.borRate*(1+d)})),         dn:pct(eu({...p,borRate:p.borRate*(1-d)}))},
    {label:"JKM (AP Alt.)", up:pct(ap(p,hh,jkm*(1+d))),                         dn:pct(ap(p,hh,jkm*(1-d)))},
  ].sort((a,b)=>Math.abs(b.up)-Math.abs(a.up)).map(r=>({subject:r.label,upside:r.up,downside:r.dn}));
}

/** calcBreakEvenMatrix v7.2 — Range Dinamico
 *  PROBLEMA v7.1: range fisso ±25% dest + ±20% HH non produce celle negative
 *  quando lo spread TTF-BEP è largo (Mar2026: TTF $12.72, BEP $8.99 → gap 29%).
 *  
 *  SOLUZIONE: il range sulla destinazione è dinamico:
 *    dstDelta = max(destUsd×0.25, destUsd - BEP_actual×0.85)
 *  Garantisce che destMin scenda sempre fino a ~15% sotto il BEP reale,
 *  rendendo sempre visibili le zone rosse anche in mercati favorevoli.
 *  Il range HH rimane ±20% (sufficiente per il driver di costo).
 */
function calcBreakEvenMatrix(params,hh,destUsd,routeId,hfoPrice){
  const STEPS=7;
  // Calcola BEP reale al centro (HH live, dest live)
  const bepCenter = calcProfit(hh,destUsd,params,routeId,hfoPrice).breakEvenDest;
  // Range dinamico: almeno ±25%, ma abbastanza da scendere a BEP×0.85
  const minDestTarget = bepCenter * 0.85;
  const dstDeltaMin   = destUsd * 0.25;
  const dstDeltaDyn   = Math.max(dstDeltaMin, destUsd - minDestTarget);
  const dstDelta      = Math.min(dstDeltaDyn, destUsd * 0.55); // cap a ±55%
  const hhDelta       = hh * 0.20;
  const hhSteps  = Array.from({length:STEPS},(_,i)=>Math.max(0.30,hh-hhDelta+(2*hhDelta/(STEPS-1))*i));
  const destSteps= Array.from({length:STEPS},(_,i)=>Math.max(1.00,destUsd-dstDelta+(2*dstDelta/(STEPS-1))*i));
  const matrix   = hhSteps.map(h=>destSteps.map(d=>{
    const res=calcProfit(h,d,params,routeId,hfoPrice);
    return{margin:res.marginPerMmbtu,bep:res.breakEvenDest,acq:res.acqPerMmbtu};
  }));
  return{hhSteps,destSteps,matrix,dstDelta,bepCenter};
}

