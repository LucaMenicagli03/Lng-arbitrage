        transition:"transform 0.26s cubic-bezier(.4,0,.2,1)",
      }}>
        <div style={{fontFamily:FC,fontSize:14,fontWeight:800,color:T.purple,
          letterSpacing:"0.08em",marginBottom:12,paddingBottom:7,
          borderBottom:`1px solid ${T.line2}`,display:"flex",
          justifyContent:"space-between",alignItems:"center"}}>
          ⚙ SCENARIO EDITOR
          <span style={{fontFamily:FM,fontSize:7.5,color:T.textDim}}>v6.1 Trader Ed.</span>
        </div>

        <Sec title="SPA Contract — Acquisition Cost" accent={T.red}
          sub={`Formula: HH×slope + tolling + liquefaction\n→ Live: $${acqDemo}/MMBtu (HH=$${hhLive.toFixed(2)})`}>
          <Param label="HH SLOPE" value={params.spaSlope} min={1.00} max={1.30} step={0.005}
            onChange={v=>onUpdate("spaSlope",v)} unit="×HH" prec={3} color={T.red}
            note="Typical SPA: 110-115% of HH"/>
          <Param label="TOLLING FEE" value={params.sTolling} min={1.00} max={5.00} step={0.05}
            onChange={v=>onUpdate("sTolling",v)} unit="$/MMBtu" prec={2} color={T.amber}
            note="Sabine Pass / Freeport tolling fee"/>
          <Param label="LIQUEFACTION" value={params.sLiquefaction} min={0.05} max={1.00} step={0.05}
            onChange={v=>onUpdate("sLiquefaction",v)} unit="$/MMBtu" prec={2} color={T.amberDim}
            note="Loading & liquefaction overhead"/>
        </Sec>

        <Sec title="Vessel & Sea State" accent={T.cyan}>
          <Param label="CAPACITY" value={params.capacityM3} min={140000} max={210000} step={1000}
            onChange={v=>onUpdate("capacityM3",v)} unit="m³" prec={0}
            note="Q-Flex 174k · Q-Max 210k"/>
          <Param label="HEEL (cooldown)" value={params.heelM3} min={500} max={4000} step={100}
            onChange={v=>onUpdate("heelM3",v)} unit="m³" prec={0} color={T.textMid}
