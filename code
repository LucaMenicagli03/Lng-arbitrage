                const active=params.seaState===k;
                return(
                  <button key={k} onClick={()=>onUpdate("seaState",k)} style={{
                    fontFamily:FC,fontSize:9,fontWeight:700,cursor:"pointer",
                    borderRadius:2,padding:"5px 6px",textAlign:"left",
                    border:`1px solid ${active?(k==="storm"?T.red:k==="rough"?T.amber:T.cyan):T.line}`,
