    </div>
  );
  const Toggle=({label,value,onChange,note,color=T.amber})=>(
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",
      marginBottom:8,padding:"5px 8px",background:T.bg2,borderRadius:2,
      border:`1px solid ${value?color:T.line}`}}>
