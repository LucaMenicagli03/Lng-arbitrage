  if(!storage)return(<Card accent={T.purple} style={{padding:"8px 10px"}}><SH label="US NG Storage — EIA" accent={T.purple} right="Weekly"/><div style={{fontFamily:FM,fontSize:8,color:T.textDim}}>EIA API fetching…</div></Card>);
  return(<Card accent={T.purple} style={{padding:"8px 10px"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5,paddingBottom:4,borderBottom:`1px solid ${T.line}`}}>
      <span style={{fontFamily:FC,fontSize:10,fontWeight:700,color:T.purple,letterSpacing:"0.14em"}}>US NG STORAGE — EIA</span>
      <DQBadge level="LIVE" source="EIA API v2"/>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:4}}>
      {[
        {l:"Working Gas",v:`${(storage.value/1000).toFixed(2)} Tcf`,c:T.cyan},
        {l:"WoW Change", v:`${storage.change>0?"+":""}${storage.change.toFixed(0)} Bcf`,c:storage.change>0?T.red:T.green},
        {l:"vs Year-Ago",v:storage.surplus!=null?`${storage.surplus>0?"+":""}${storage.surplus.toFixed(0)} Bcf`:"—",c:storage.surplus>0?T.red:T.green},
        {l:"HH Signal",  v:storage.bullish?"BULLISH ▲":"BEARISH ▼",c:storage.bullish?T.green:T.red},
      ].map((s,i)=>(<div key={i}><div style={{fontFamily:FC,fontSize:8,color:T.textDim}}>{s.l}</div><div style={{fontFamily:FM,fontSize:10,fontWeight:700,color:s.c}}>{s.v}</div></div>))}
    </div>
    <div style={{fontFamily:FM,fontSize:7,color:T.textDim,marginTop:3}}>Dato: {storage.period}</div>
  </Card>);
}

