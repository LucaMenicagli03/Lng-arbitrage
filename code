          {/* FX status */}
          <div style={{fontFamily:FONT_MONO,fontSize:9,color:T.textMid,
            background:T.bg2,border:`1px solid ${T.line}`,padding:"4px 9px",borderRadius:2,
            display:"flex",alignItems:"center",gap:5}}>
            <span style={{color:fxOk&&fxAge<90?T.green:T.amber,fontSize:10}}>●</span>
            FX BCE {fxOk?`${fxAge}s ago`:"fallback"}
          </div>
          {/* Vol mode */}
          <div style={{display:"flex",gap:4}}>
            {["low","normal","high"].map(v=>(
              <button key={v} className={`ctrl ${volMode===v?"active":""}`}
                onClick={()=>setVolMode(v)}>σ {v}</button>
            ))}
          </div>
          <button className="ctrl" onClick={()=>setIsLive(l=>!l)}
            style={{color:isLive?T.red:T.green,borderColor:isLive?T.red:T.green,
              background:isLive?`${T.red}12`:`${T.green}12`}}>
            {isLive?"⏸ STOP":"▶ LIVE"}
          </button>
          <div style={{display:"flex",alignItems:"center",gap:5,
            fontFamily:FONT_MONO,fontSize:10,color:T.textMid}}>
            <div className={isLive?"live-dot":""} style={{width:6,height:6,
              borderRadius:"50%",background:isLive?T.green:T.textDim}} />
            {isLive?"LIVE":"PAUSED"}  ·  tick #{tick}
          </div>
        </div>
      </div>

      {/* ══ TICKER STRIP ═════════════════════════════════════════════ */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:7,marginBottom:9}}>
        <Ticker label="HENRY HUB"   value={f3(px.hh)}    delta={px.hh-(prevPx?.hh??px.hh)}               unit="$/MMBtu"  color={T.green}/>
        <Ticker label="TTF"         value={f3(px.ttf)}   delta={px.ttf-(prevPx?.ttf??px.ttf)}             unit="€/MWh"    color={T.cyan}/>
        <Ticker label="TTF (USD)"   value={f3(ttfUsd)}   delta={ttfUsd-prevTtfUsd}                        unit="$/MMBtu"  color={T.cyan}/>
        <Ticker label="JKM"         value={f3(px.jkm)}   delta={px.jkm-(prevPx?.jkm??px.jkm)}             unit="$/MMBtu"  color={T.amber}/>
        <Ticker label="EUR/USD"     value={f3(px.eurUsd)}delta={px.eurUsd-(prevPx?.eurUsd??px.eurUsd)}     unit=""         color={T.purple}/>
        <Ticker label="SPREAD EU"   value={f3(spreadEu)} delta={spreadEu-(ttfToUsd(prevPx?.ttf??px.ttf,px.eurUsd)-(prevPx?.hh??px.hh))} unit="$/MMBtu" color={spreadEu>0?T.green:T.red}/>
        <Ticker label="SPREAD APAC" value={f3(spreadAp)} delta={spreadAp-((prevPx?.jkm??px.jkm)-(prevPx?.hh??px.hh))} unit="$/MMBtu" color={spreadAp>0?T.green:T.red}/>
      </div>

      {/* ══ ROW 2: Prezzi + Spread + Profitti ════════════════════════ */}
      <div style={{display:"grid",gridTemplateColumns:"2fr 1fr 1fr",gap:7,marginBottom:7}}>
        <Card accent={T.cyan}>
          <SH label="Prezzi Spot — OU Mean-Reversion" right={`σ=${volMode}  |  ${ts()}`}/>
          <ResponsiveContainer width="100%" height={172}>
            <LineChart data={history} margin={{top:2,right:4,bottom:0,left:-20}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="t" tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                interval={Math.floor(history.length/5)}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}/>
              <Tooltip content={<Tip dec={3}/>}/>
              <Line dataKey="hh"  name="HH"   stroke={T.green} dot={false} strokeWidth={1.6} isAnimationActive={false}/>
              <Line dataKey="ttf" name="TTF$" stroke={T.cyan}  dot={false} strokeWidth={1.6} isAnimationActive={false}/>
              <Line dataKey="jkm" name="JKM"  stroke={T.amber} dot={false} strokeWidth={1.6} isAnimationActive={false}/>
            </LineChart>
          </ResponsiveContainer>
        </Card>

        <Card accent={T.green}>
          <SH label="Spread Arbitrage" right="HH→TTF  /  HH→JKM"/>
          <ResponsiveContainer width="100%" height={172}>
            <ComposedChart data={spreadH} margin={{top:2,right:4,bottom:0,left:-22}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="t" tick={{fill:T.textDim,fontSize:7,fontFamily:FONT_MONO}}
                interval={Math.floor(spreadH.length/4)}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                tickFormatter={v=>`$${v.toFixed(1)}`}/>
              <ReferenceLine y={0} stroke="white" strokeDasharray="3 2" strokeOpacity={0.35}/>
              <Tooltip content={<Tip dec={3}/>}/>
              <defs>
                <linearGradient id="gEu" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%"  stopColor={T.cyan} stopOpacity={0.28}/>
                  <stop offset="95%" stopColor={T.cyan} stopOpacity={0}/>
                </linearGradient>
              </defs>
              <Area dataKey="eu" name="Spread EU" stroke={T.cyan} fill="url(#gEu)"
                strokeWidth={1.8} dot={false} isAnimationActive={false}/>
              <Line dataKey="ap" name="Spread AP" stroke={T.amber} dot={false}
                strokeWidth={1.6} strokeDasharray="4 2" isAnimationActive={false}/>
            </ComposedChart>
          </ResponsiveContainer>
        </Card>

        <Card accent={T.amber}>
          <SH label="Profitto Netto Live" right="EU  vs  APAC (M$)"/>
          <ResponsiveContainer width="100%" height={172}>
            <ComposedChart data={profitH} margin={{top:2,right:4,bottom:0,left:-14}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="t" tick={{fill:T.textDim,fontSize:7,fontFamily:FONT_MONO}}
                interval={Math.floor(profitH.length/4)}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                tickFormatter={v=>`${v.toFixed(1)}M`}/>
              <ReferenceLine y={0} stroke="white" strokeDasharray="3 2" strokeOpacity={0.35}/>
              <Tooltip content={<Tip pre="" dec={2}/>}/>
              <defs>
                <linearGradient id="gP" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%"  stopColor={T.cyan} stopOpacity={0.22}/>
                  <stop offset="95%" stopColor={T.cyan} stopOpacity={0}/>
                </linearGradient>
              </defs>
              <Area dataKey="eu" name="EU M$" stroke={T.cyan} fill="url(#gP)"
                strokeWidth={2} dot={false} isAnimationActive={false}/>
              <Line dataKey="ap" name="AP M$" stroke={T.amber} strokeWidth={2}
                dot={false} strokeDasharray="4 2" isAnimationActive={false}/>
            </ComposedChart>
          </ResponsiveContainer>
        </Card>
      </div>

      {/* ══ ROW 3: MC + Waterfall + Forward ══════════════════════════ */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1.15fr 1.15fr",gap:7,marginBottom:7}}>

        <Card accent={T.cyan}>
          <SH label="Monte Carlo Distribution" right="500 sim · OU · Cholesky"/>
          {mc&&(
            <>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5,marginBottom:8}}>
                {[
                  {l:"E[Profit]", v:fMa(mc.mean),              c:pColor(mc.mean)},
                  {l:"VaR 95%",   v:fMa(mc.var95),             c:T.red},
                  {l:"P(Profit)", v:`${mc.probP.toFixed(1)}%`,  c:mc.probP>60?T.green:T.red},
                  {l:"Sharpe",    v:mc.sharpe.toFixed(3),       c:T.amber},
                ].map((s,i)=>(
                  <div key={i} style={{background:T.bg2,padding:"5px 8px",borderRadius:2}}>
                    <div style={{fontFamily:FONT_COND,fontSize:9,color:T.textMid,letterSpacing:"0.1em"}}>{s.l}</div>
                    <div style={{fontFamily:FONT_MONO,fontSize:14,fontWeight:700,color:s.c}}>{s.v}</div>
                  </div>
                ))}
              </div>
              <ResponsiveContainer width="100%" height={115}>
                <BarChart data={mc.bins} margin={{top:0,right:2,bottom:0,left:-26}}>
                  <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
                  <XAxis dataKey="x" tick={{fill:T.textDim,fontSize:7,fontFamily:FONT_MONO}}
                    tickFormatter={v=>`${v}M`} interval={5}/>
                  <YAxis tick={{fill:T.textDim,fontSize:7,fontFamily:FONT_MONO}}/>
                  <ReferenceLine x="0.00" stroke="white" strokeDasharray="3 2" strokeOpacity={0.5}/>
                  <Tooltip content={<Tip pre="" dec={0}/>}/>
                  <Bar dataKey="n" name="Freq" isAnimationActive={false} radius={[1,1,0,0]}>
                    {mc.bins.map((d,i)=><Cell key={i} fill={d.pos?`${T.cyan}CC`:`${T.red}CC`}/>)}
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </>
          )}
        </Card>

        <Card accent={T.amber}>
          <SH label="Cost / Revenue Breakdown" right="Sabine Pass → Rotterdam  (M$)"/>
          <ResponsiveContainer width="100%" height={182}>
            <BarChart data={wf} margin={{top:2,right:6,bottom:0,left:-12}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4" vertical={false}/>
              <XAxis dataKey="n" tick={{fill:T.textMid,fontSize:9,fontFamily:FONT_COND,fontWeight:700}}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                tickFormatter={v=>`${v.toFixed(1)}M`}/>
              <ReferenceLine y={0} stroke="white" strokeOpacity={0.4}/>
              <Tooltip content={<Tip pre="" dec={2}/>}/>
              <Bar dataKey="v" name="M$" isAnimationActive={false} radius={[2,2,0,0]}>
                {wf.map((d,i)=><Cell key={i} fill={d.fill}/>)}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </Card>

        <Card accent={T.purple}>
          <SH label="Forward Curve — 12M (OU projection)"
            right={<Badge label={curveLbl} color={curveCol}/>}/>
          <ResponsiveContainer width="100%" height={182}>
            <LineChart data={fwd} margin={{top:2,right:6,bottom:0,left:-14}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="m" tick={{fill:T.textDim,fontSize:9,fontFamily:FONT_MONO}}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}/>
              <Tooltip content={<Tip dec={2}/>}/>
              <Line dataKey="ttf" name="TTF$" stroke={T.cyan}   dot={{r:2,fill:T.cyan}}   strokeWidth={2} isAnimationActive={false}/>
              <Line dataKey="jkm" name="JKM"  stroke={T.amber}  dot={{r:2,fill:T.amber}}  strokeWidth={2} isAnimationActive={false}/>
              <Line dataKey="hh"  name="HH"   stroke={T.green}  dot={{r:2,fill:T.green}}  strokeWidth={2} isAnimationActive={false}/>
            </LineChart>
          </ResponsiveContainer>
        </Card>
      </div>

      {/* ══ ROW 4: Sensitività + Boil-off + Decision ═════════════════ */}
      <div style={{display:"grid",gridTemplateColumns:"1.4fr 1fr 1.3fr",gap:7,marginBottom:8}}>

        <Card accent={T.cyan}>
          <SH label="Sensitività: Profitto vs Charter Rate" right={`attuale ${fK(charter)}/d`}/>
          <div style={{display:"flex",alignItems:"center",gap:9,marginBottom:8}}>
            <span style={{fontFamily:FONT_COND,fontSize:10,color:T.textMid,whiteSpace:"nowrap"}}>
              Charter Rate:
            </span>
            <input type="range" min={40000} max={140000} step={5000}
              value={charter} onChange={e=>setCharter(+e.target.value)}/>
            <span style={{fontFamily:FONT_MONO,fontSize:11,fontWeight:700,color:T.cyan,whiteSpace:"nowrap"}}>
              {fK(charter)}/d
            </span>
          </div>
          <ResponsiveContainer width="100%" height={145}>
            <ComposedChart data={sensi} margin={{top:2,right:6,bottom:0,left:-12}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="cr" tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                tickFormatter={v=>`$${v}k`}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                tickFormatter={v=>`${v.toFixed(0)}M`}/>
              <ReferenceLine y={0} stroke="white" strokeDasharray="3 2" strokeOpacity={0.4}/>
              <ReferenceLine x={charter/1000} stroke={T.amber} strokeDasharray="4 2"
                label={{value:"●",fill:T.amber,fontSize:13,position:"insideTopRight"}}/>
              <Tooltip content={<Tip pre="" dec={2}/>}/>
              <defs>
                <linearGradient id="gS" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%"  stopColor={T.cyan} stopOpacity={0.3}/>
                  <stop offset="95%" stopColor={T.cyan} stopOpacity={0}/>
                </linearGradient>
              </defs>
              <Area dataKey="p" name="Profit M$" stroke={T.cyan} fill="url(#gS)"
                strokeWidth={2.2} dot={false} isAnimationActive={false}/>
            </ComposedChart>
          </ResponsiveContainer>
        </Card>

        <Card accent={T.red}>
          <SH label="Boil-Off Decay Curve" right="0.10 / 0.15 / 0.20 %/d"/>
          <ResponsiveContainer width="100%" height={172}>
            <LineChart data={boiloff} margin={{top:2,right:4,bottom:0,left:-20}}>
              <CartesianGrid stroke={T.line} strokeDasharray="2 4"/>
              <XAxis dataKey="d" tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                label={{value:"days",fill:T.textDim,fontSize:8,position:"insideBottomRight",offset:-2}}/>
              <YAxis tick={{fill:T.textDim,fontSize:8,fontFamily:FONT_MONO}}
                domain={[90,100]} tickFormatter={v=>`${v}%`}/>
              <ReferenceLine x={travelDays(ROUTES[0].nm)} stroke={T.cyan}
                strokeDasharray="3 2" label={{value:"EU",fill:T.cyan,fontSize:8,position:"insideTopRight"}}/>
              <ReferenceLine x={travelDays(ROUTES[1].nm)} stroke={T.amber}
                strokeDasharray="3 2" label={{value:"AP",fill:T.amber,fontSize:8,position:"insideTopRight"}}/>
              <Tooltip content={<Tip pre="" dec={2}/>}/>
              <Line dataKey="lo" name="0.10%/d" stroke={T.green} dot={false} strokeWidth={1.8} isAnimationActive={false}/>
              <Line dataKey="nm" name="0.15%/d" stroke={T.amber} dot={false} strokeWidth={1.8} isAnimationActive={false}/>
              <Line dataKey="hi" name="0.20%/d" stroke={T.red}   dot={false} strokeWidth={1.8} isAnimationActive={false}/>
            </LineChart>
          </ResponsiveContainer>
        </Card>

        <Card accent={T.green}>
          <SH label="Decision Engine — Optimal Routing" right={ts()}/>
          <div style={{display:"flex",flexDirection:"column",gap:7}}>

            {/* Optimal block */}
            <div style={{background:`${T.green}0C`,border:`1px solid ${T.green}2A`,
              borderLeft:`3px solid ${T.green}`,padding:"9px 11px",borderRadius:2}}>
              <div style={{fontFamily:FONT_COND,fontSize:9,color:T.textMid,
                letterSpacing:"0.14em",marginBottom:3}}>DESTINAZIONE OTTIMALE</div>
              <div style={{fontFamily:FONT_COND,fontSize:19,fontWeight:800,color:T.green,lineHeight:1}}>
                {optimal.r.label} <span style={{fontSize:13,color:T.greenDim}}>({optimal.r.dest})</span>
              </div>
              <div style={{fontFamily:FONT_MONO,fontSize:9,color:T.textMid,marginTop:2}}>
                {optimal.r.name}
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginTop:8}}>
                {[
                  {l:"NET PROFIT",  v:fM(optimal.p.profit),                     c:pColor(optimal.p.profit)},
                  {l:"$/MMBtu",     v:(optimal.p.profit/optimal.p.deliv).toFixed(2), c:T.text},
                  {l:"TRAVEL",      v:`${optimal.p.td.toFixed(1)}d`,             c:T.textMid},
                ].map((s,i)=>(
                  <div key={i}>
                    <div style={{fontFamily:FONT_COND,fontSize:8,color:T.textMid,letterSpacing:"0.1em"}}>{s.l}</div>
                    <div style={{fontFamily:FONT_MONO,fontSize:14,fontWeight:700,color:s.c}}>{s.v}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Route comparison */}
            {[{r:ROUTES[0],p:pEu,sp:spreadEu},{r:ROUTES[1],p:pAp,sp:spreadAp}].map((item,i)=>(
              <div key={i} style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:5,
                background:T.bg2,padding:"7px 9px",borderRadius:2,
                border:`1px solid ${item.r.id===optimal.r.id?T.green:T.line}`}}>
                <div>
                  <div style={{fontFamily:FONT_COND,fontSize:8,color:T.textMid}}>ROTTA</div>
                  <div style={{fontFamily:FONT_COND,fontSize:12,fontWeight:700,
                    color:item.r.id===optimal.r.id?T.green:T.text}}>
                    {item.r.dest} {item.r.id===optimal.r.id?"★":""}
                  </div>
                </div>
                <div>
                  <div style={{fontFamily:FONT_COND,fontSize:8,color:T.textMid}}>PROFIT</div>
                  <div style={{fontFamily:FONT_MONO,fontSize:11,fontWeight:700,color:pColor(item.p.profit)}}>
                    {fMa(item.p.profit)}
                  </div>
                </div>
                <div>
                  <div style={{fontFamily:FONT_COND,fontSize:8,color:T.textMid}}>SPREAD</div>
                  <div style={{fontFamily:FONT_MONO,fontSize:11,fontWeight:700,color:pColor(item.sp)}}>
                    ${item.sp.toFixed(2)}
                  </div>
                </div>
                <div style={{display:"flex",alignItems:"flex-end"}}>
                  <Badge label={item.p.profit>0?"ARBIT":"LOSS"} color={item.p.profit>0?T.green:T.red}/>
                </div>
              </div>
            ))}

            {/* MC + FWD summary */}
            {mc&&(
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:5}}>
                {[
                  {l:"MC E[P]",    v:fMa(mc.mean),              c:pColor(mc.mean)},
                  {l:"P(profit)", v:`${mc.probP.toFixed(0)}%`,  c:mc.probP>60?T.green:T.red},
                  {l:"FWD CURVE", v:curveLbl,                   c:curveCol},
                ].map((s,i)=>(
                  <div key={i} style={{background:T.bg2,padding:"5px 7px",borderRadius:2}}>
                    <div style={{fontFamily:FONT_COND,fontSize:8,color:T.textMid,letterSpacing:"0.1em"}}>{s.l}</div>
                    <div style={{fontFamily:FONT_MONO,fontSize:12,fontWeight:700,color:s.c}}>{s.v}</div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </Card>
      </div>

      {/* ══ FOOTER ═══════════════════════════════════════════════════ */}
      <div style={{borderTop:`1px solid ${T.line}`,paddingTop:8,
        display:"flex",justifyContent:"space-between",alignItems:"center",
        flexWrap:"wrap",gap:5}}>
        <div style={{fontFamily:FONT_MONO,fontSize:9,color:T.textDim}}>
          ⚙ OU κ={OU_KAPPA}  ·  Cholesky σ={JSON.stringify(VOL_PRESETS[volMode])}
          ·  Charter ${fK(charter)}/d  ·  Q-Flex 174k m³ / {CAP_MMBTU.toLocaleString("it-IT")} MMBtu
        </div>
        <div style={{fontFamily:FONT_MONO,fontSize:9,color:T.textDim,textAlign:"center"}}>
          <span style={{color:fxOk?T.green:T.amber}}>● </span>
          FX: Frankfurter/BCE (gratuita, no-key)  ·  HH/TTF: seed EIA avg 2025 + OU  ·  JKM: proxy HH×3.8+1.5
        </div>
        <div style={{fontFamily:FONT_MONO,fontSize:9,color:T.textDim}}>
          {new Date().toLocaleString("it-IT")}  ·  #{tick}
        </div>
      </div>
    </div>
  );
}
